	(title_block
		(title "24_WATCHDOG_SUPERVISOR - reset, fault manager and containment")
		(date "2026-07-15")
		(rev "B1")
		(company "Gonoboben/plataVM")
		(comment 1 "Interface consistency: watchdog, EMG, fault summary and controlled-shutdown ports")
		(comment 2 "No watchdog, supervisor, latch, gate, isolator, reset IC or footprint selected")
	)
	(lib_symbols)
	(text "24_WATCHDOG_SUPERVISOR - PURPOSE\nDefines independent supervision and fault containment for the critical control domain.\nThe block supervises MCU activity, critical power and EMG health and can force defined safe states.\nIt does not replace the separate EXT_KILL hardware chain."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.24 1.24)) (justify left))
		(uuid "ctrl-reserve-00000024-0000-4000-8000-000000000101")
	)
	(text "WATCHDOG / RESET\nFuture watchdog receives WATCHDOG_KICK and may use MCU_RUN_STATUS for observation.\nIt creates MCU_RESET_N when heartbeat or timing requirements are violated.\nTimeout, startup window, reset pulse and service override policy remain TBD."
		(exclude_from_sim no)
		(at 12 70 0)
		(effects (font (size 1.16 1.16)) (justify left))
		(uuid "ctrl-reserve-00000024-0000-4000-8000-000000000102")
	)
	(text "FAULT MANAGER\nBFE_FAULT_SUMMARY_N and board-level faults from PCB-C/D/E are aggregated with CRIT_POWER_FAULT_N and EMG_FAULT_N.\nFAULT_MANAGER_SAFE_OFF requests non-emergency load containment.\nCONTROLLED_SHUTDOWN_REQ requests orderly MCU logging/shutdown without replacing hardware OFF."
		(exclude_from_sim no)
		(at 12 132 0)
		(effects (font (size 1.13 1.13)) (justify left))
		(uuid "ctrl-reserve-00000024-0000-4000-8000-000000000103")
	)
	(text "PRIORITY / RECOVERY\nEXT_KILL_LATCHED has higher priority than MCU commands, watchdog recovery and service actions.\nFAULT_LATCHED_STATUS may be read by the MCU and RS-485 path.\nClearing faults must not automatically restart K_BAT1/K_BAT2 or re-enable high-current loads."
		(exclude_from_sim no)
		(at 12 202 0)
		(effects (font (size 1.16 1.16)) (justify left))
		(uuid "ctrl-reserve-00000024-0000-4000-8000-000000000104")
	)

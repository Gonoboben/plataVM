	(title_block
		(title "55_LIGHT_DIAGNOSTICS - channel and board diagnostics")
		(date "2026-07-15")
		(rev "B0")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A/B: six-channel and board-level diagnostic aggregation")
		(comment 2 "No ADC, mux, controller, sensor, serializer, isolator or footprint selected")
	)
	(lib_symbols)
	(text "55_LIGHT_DIAGNOSTICS - PURPOSE\nAggregates six per-channel fault/current diagnostics and board observations toward PCB-B.\nChannel identity is preserved; physical parallel, muxed analog or local digital transport remains TBD.\nDiagnostics are not required for LIGHT_GROUP_HARD_OFF action."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.18 1.18)) (justify left))
		(uuid "light-power-00000055-0000-4000-8000-000000000101")
	)
	(text "CANONICAL DIAGNOSTICS\nLED_FAULT_N_1_3 plus LED_FAULT_N_4_6 form LED_FAULT_N[1..6].\nLED_ISENSE_1_3 plus LED_ISENSE_4_6 form LED_ISENSE[1..6].\nLIGHT_INPUT_VSENSE, LIGHT_BOARD_TEMP and LIGHT_BOARD_FAULT_N are board-level outputs."
		(exclude_from_sim no)
		(at 12 78 0)
		(effects (font (size 1.08 1.08)) (justify left))
		(uuid "light-power-00000055-0000-4000-8000-000000000102")
	)
	(text "FAULT / THERMAL AGGREGATION\nLIGHT_BOARD_FAULT_N may combine input, thermal and critical driver faults without hiding individual LED_FAULT_N bits.\nTwo zone-temperature inputs may be combined into LIGHT_BOARD_TEMP only after sensor placement and thermal model are defined.\nThresholds, latching, debounce, calibration and retry policy remain TBD."
		(exclude_from_sim no)
		(at 12 138 0)
		(effects (font (size 1.06 1.06)) (justify left))
		(uuid "light-power-00000055-0000-4000-8000-000000000103")
	)

	(uuid "ctrl-reserve-0000-4000-8000-000000000025")
	(paper "A3")
	(title_block
		(title "25_RS485_ISOLATED - external half-duplex communication boundary")
		(date "2026-07-15")
		(rev "B0")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A/B: isolated external RS-485 logic, barrier and cable-side domains")
		(comment 2 "No transceiver, digital isolator, isolated supply, termination, TVS, connector or footprint selected")
	)
	(lib_symbols)
	(text "25_RS485_ISOLATED - PURPOSE\nDefines the active external communication interface of PCB-B_CTRL_RESERVE.\nThe external interface is isolated RS-485 half-duplex.\nOptional CAN/CAN-FD remains future/DNP only and no footprint is created in this stage."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.28 1.28)) (justify left))
		(uuid "ctrl-reserve-00000025-0000-4000-8000-000000000101")
	)
	(text "LOGIC-SIDE DOMAIN\nRS485_TX, RS485_RX and RS485_DE belong to the critical control domain referenced to SIGNAL_GND.\nProtocol timing, failsafe behavior and direction-control implementation remain TBD.\nCommunication loss must default control outputs to their separately defined safe states."
		(exclude_from_sim no)
		(at 12 72 0)
		(effects (font (size 1.16 1.16)) (justify left))
		(uuid "ctrl-reserve-00000025-0000-4000-8000-000000000102")
	)
	(text "ISOLATION BARRIER / CABLE SIDE\nFuture isolation and isolated-power topology shall keep ISO_GND separate from SIGNAL_GND and POWER_GND.\nRS485_A_ISO and RS485_B_ISO are cable-side logical ports.\nIsolation rating, surge protection, common-mode range, termination and biasing require later calculation."
		(exclude_from_sim no)
		(at 12 134 0)
		(effects (font (size 1.16 1.16)) (justify left))
		(uuid "ctrl-reserve-00000025-0000-4000-8000-000000000103")
	)
	(text "SHIELD / CHASSIS POLICY\nCable shield and CHASSIS termination are not selected here.\nNo automatic bond between ISO_GND, SIGNAL_GND, POWER_GND and CHASSIS is permitted.\nThe selected physical connector and cable pair must be defined in a later interface/mechanical stage."
		(exclude_from_sim no)
		(at 12 202 0)
		(effects (font (size 1.16 1.16)) (justify left))
		(uuid "ctrl-reserve-00000025-0000-4000-8000-000000000104")
	)

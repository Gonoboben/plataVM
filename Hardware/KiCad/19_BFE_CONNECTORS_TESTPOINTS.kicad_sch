	(lib_symbols)
	(text "19_BFE_CONNECTORS_TESTPOINTS - FUNCTIONAL PURPOSE\nCollect connector and testpoint boundaries for PCB-A_BFE_POWER.\nIncludes external battery interfaces, PACK_BUS fanout, control/diagnostic link to PCB-B, EXT_KILL path and service testpoints.\nThis sheet does not choose physical connector family, pin pitch, locking style, wire section or footprint."
		(exclude_from_sim no)
		(at 12 18 0)
		(effects (font (size 1.45 1.45)) (justify left))
		(uuid "bfe-dh-00000019-0000-4000-8000-000000000101")
	)
	(text "CONNECTOR GROUPS\n- BAT1/BAT2 SN-176A-12 mating boundary already defined externally;\n- PACK_BUS_CRIT/P12/P5/LIGHT outgoing groups;\n- PCB-B control/diagnostics low-speed group;\n- EXT_KILL hardware chain;\n- BFE testpoints for bring-up and fault injection."
		(exclude_from_sim no)
		(at 12 84 0)
		(effects (font (size 1.35 1.35)) (justify left))
		(uuid "bfe-dh-00000019-0000-4000-8000-000000000102")
	)
	(text "OPEN ITEMS\nConnector family, pin count, creepage/clearance, current rating, shielding, keying, cable colors, service access and testpoint protection remain TBD.\nDo not use connector grouping to change electrical architecture."
		(exclude_from_sim no)
		(at 12 146 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "bfe-dh-00000019-0000-4000-8000-000000000103")
	)

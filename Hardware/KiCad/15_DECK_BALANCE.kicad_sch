	(title_block
		(title "15_DECK_BALANCE - controlled equalization path")
		(date "2026-07-15")
		(rev "B1")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level B: balance control, measurement dependency and abort nets")
		(comment 2 "No resistor, switch, current value or thermal solution selected")
	)
	(lib_symbols)
	(text "15_DECK_BALANCE - LEVEL B FUNCTIONAL NETS\nDeck-side balancing is a controlled maintenance/state-machine function after work, not an always-on passive equalizer.\nIt uses BAT1/BAT2 balance tap groups and a current-limited BALANCE_PATH_TBD.\nIt must not bypass BMS protection or replace branch fault handling."
		(exclude_from_sim no)
		(at 12 18 0)
		(effects (font (size 1.35 1.35)) (justify left))
		(uuid "bfe-lb-00000015-0000-4000-8000-000000000101")
	)
	(text "CONTROL AND ABORT\nBALANCE_ARM permits the function only in allowed system states.\nBALANCE_SW1_EN and BALANCE_SW2_EN command branch-side switching boundaries.\nBALANCE_ABORT and EXT_KILL_HW_CHAIN must disable the path.\nBalance current, delta-V limits, duration and thermal model remain TBD."
		(exclude_from_sim no)
		(at 12 82 0)
		(effects (font (size 1.25 1.25)) (justify left))
		(uuid "bfe-lb-00000015-0000-4000-8000-000000000102")
	)
	(text "DIAGNOSTICS\nDIAG_BALANCE_I, DIAG_BALANCE_TEMP and DIAG_BALANCE_STATUS are logical groups to PCB-B.\nThe final circuit must provide timeout/fault logging and fail toward OFF.\nR_BAL, switch SOA, thermal sensor placement and protection remain TBD."
		(exclude_from_sim no)
		(at 12 152 0)
		(effects (font (size 1.25 1.25)) (justify left))
		(uuid "bfe-lb-00000015-0000-4000-8000-000000000103")
	)

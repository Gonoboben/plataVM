	(lib_symbols)
	(text "15_DECK_BALANCE - SYMBOL SKELETON ZONES\nDeck-side balancing is only allowed after work / under controlled conditions.\nIt is not an always-on passive equalizer and must not bypass BMS protection.\nThis sheet reserves placeholders for later balance path implementation."
		(exclude_from_sim no)
		(at 12 16 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "bfe-lb-00000015-0000-4000-8000-000000000101")
	)
	(text "PLACEHOLDER ZONE: BAL15_PATH_TBD\nFuture current-limited equalization path between BALANCE_TAP_BAT1 and BALANCE_TAP_BAT2.\nR_BAL value, power, thermal placement, allowed delta-V and duration remain TBD."
		(exclude_from_sim no)
		(at 12 70 0)
		(effects (font (size 1.22 1.22)) (justify left))
		(uuid "bfe-lb-00000015-0000-4000-8000-000000000102")
	)
	(text "PLACEHOLDER ZONE: BAL15_SWITCHES_TBD\nFuture BALANCE_ARM / BALANCE_SW1_EN / BALANCE_SW2_EN implementation.\nMust be blocked by unsafe states, EXT_KILL and BALANCE_ABORT.\nSwitch SOA and fault behavior remain TBD."
		(exclude_from_sim no)
		(at 12 116 0)
		(effects (font (size 1.22 1.22)) (justify left))
		(uuid "bfe-lb-00000015-0000-4000-8000-000000000103")
	)
	(text "PLACEHOLDER ZONE: BAL15_DIAG_TBD\nFuture balance current, temperature and status diagnostics.\nDiagnostics shall support timeout/fault logging but must not enable balancing by themselves."
		(exclude_from_sim no)
		(at 12 166 0)
		(effects (font (size 1.22 1.22)) (justify left))
		(uuid "bfe-lb-00000015-0000-4000-8000-000000000104")
	)

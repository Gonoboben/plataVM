		(title "15_DECK_BALANCE - controlled equalization path")
		(date "2026-07-15")
		(rev "A1")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A: deck-side balance functional boundary")
		(comment 2 "No resistor, switch or control topology selected")
	)
	(lib_symbols)
	(text "15_DECK_BALANCE - FUNCTIONAL PURPOSE\nDeck-side balancing is performed only after work / under controlled conditions.\nIt is not an always-on passive equalizer and does not bypass BMS protection.\nThe balance path is commanded by MCU logic and must be blocked by unsafe states."
		(exclude_from_sim no)
		(at 12 18 0)
		(effects (font (size 1.45 1.45)) (justify left))
		(uuid "bfe-dh-00000015-0000-4000-8000-000000000101")
	)
	(text "FUNCTIONAL BLOCKS\n- BALANCE_SW1 / BALANCE_SW2 command boundary;\n- R_BAL / current-limited equalization path TBD;\n- voltage/current monitoring dependency;\n- firmware interlock dependency;\n- thermal timeout and fault logging dependency."
		(exclude_from_sim no)
		(at 12 78 0)
		(effects (font (size 1.35 1.35)) (justify left))
		(uuid "bfe-dh-00000015-0000-4000-8000-000000000102")
	)
	(text "OPEN ITEMS\nBalance current, allowed delta-V, resistor power, switch SOA, thermal sensor placement, duration and abort logic remain TBD.\nDo not use balancing as a substitute for BMS protection or main branch fault handling."
		(exclude_from_sim no)
		(at 12 140 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "bfe-dh-00000015-0000-4000-8000-000000000103")
	)

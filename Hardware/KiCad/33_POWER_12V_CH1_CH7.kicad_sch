	(paper "A3")
	(title_block
		(title "33_POWER_12V_CH1_CH7 - controlled output group")
		(date "2026-07-15")
		(rev "B0")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A/B: seven independent MCU-controlled 12 V channels")
		(comment 2 "No switch, protection, sensor, suppression, connector or footprint selected")
	)
	(lib_symbols)
	(text "33_POWER_12V_CH1_CH7 - PURPOSE\nDefines seven electrically independent channel instances based on the functional contract of sheet 32.\nEach channel has its own normal enable, protection boundary, output and diagnostic pair.\nThe group shares only the protected input bus and group SAFE/HARD_OFF commands."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.22 1.22)) (justify left))
		(uuid "power-12v-00000033-0000-4000-8000-000000000101")
	)
	(text "CONTROLLED CHANNELS CH1..CH7\nP12_CH_EN_1_7 represents seven independent normal-control enables from PCB-B.\nP12_GROUP_SAFE_OFF and P12_GROUP_HARD_OFF override every channel enable.\nOne channel fault must remain contained where protection coordination permits."
		(exclude_from_sim no)
		(at 12 76 0)
		(effects (font (size 1.14 1.14)) (justify left))
		(uuid "power-12v-00000033-0000-4000-8000-000000000102")
	)
	(text "POWER / THERMAL BOUNDARY\nAll seven channels draw from P12_PROTECTED_BUS and return through POWER_GND.\nThe nominal 3 A per-channel requirement does not imply fourteen channels may operate at maximum simultaneously without branch and thermal calculation.\nCopper, busbar, cooling and simultaneous-load limits remain TBD."
		(exclude_from_sim no)
		(at 12 138 0)
		(effects (font (size 1.10 1.10)) (justify left))
		(uuid "power-12v-00000033-0000-4000-8000-000000000103")
	)
	(text "DIAGNOSTIC GROUPS\nP12_CH_FAULT_N_1_7 and P12_CH_ISENSE_1_7 preserve channel identity.\nNo diagnostic aggregation may prevent direct HARD_OFF behavior.\nParallel versus local multiplexed/digital transport remains TBD."
		(exclude_from_sim no)
		(at 12 208 0)
		(effects (font (size 1.14 1.14)) (justify left))
		(uuid "power-12v-00000033-0000-4000-8000-000000000104")
	)

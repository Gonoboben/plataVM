	(paper "A3")
	(title_block
		(title "28_SERVICE_DEBUG - controlled service and programming boundary")
		(date "2026-07-15")
		(rev "B0")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A/B: SWD, service UART, boot/config and operational isolation rules")
		(comment 2 "No debug probe connector, UART transceiver, USB bridge, test header, ESD part or footprint selected")
	)
	(lib_symbols)
	(text "28_SERVICE_DEBUG - PURPOSE\nDefines service-only access to PCB-B_CTRL_RESERVE.\nSWD and service UART are not operational control interfaces and are not exposed through the external isolated RS-485 boundary.\nPhysical connector, pinout and service cable remain TBD."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.28 1.28)) (justify left))
		(uuid "ctrl-reserve-00000028-0000-4000-8000-000000000101")
	)
	(text "SWD / PROGRAMMING ZONE\nFuture SWD signals, reset access and programming power reference are grouped here.\nProgramming must not source uncontrolled power into an unpowered PCB-B.\nDebug attachment state and isolation from external equipment require a later electrical decision."
		(exclude_from_sim no)
		(at 12 76 0)
		(effects (font (size 1.16 1.16)) (justify left))
		(uuid "ctrl-reserve-00000028-0000-4000-8000-000000000102")
	)
	(text "SERVICE UART / BOOT CONFIG\nService UART is local/service only; electrical level, buffering and connector family remain TBD.\nBoot/config straps must have deterministic operational defaults.\nNo service command may bypass output safe defaults, fault latches, EXT_KILL or HARD_OFF."
		(exclude_from_sim no)
		(at 12 140 0)
		(effects (font (size 1.16 1.16)) (justify left))
		(uuid "ctrl-reserve-00000028-0000-4000-8000-000000000103")
	)
	(text "TEST / AUTHORIZATION POLICY\nOperational mode shall restore watchdog and supervisor behavior after service access.\nEXT_KILL_LATCHED can be observed but not overridden by debug tooling.\nAny authorized reset path must be physically and procedurally separated from ordinary firmware commands."
		(exclude_from_sim no)
		(at 12 204 0)
		(effects (font (size 1.16 1.16)) (justify left))
		(uuid "ctrl-reserve-00000028-0000-4000-8000-000000000104")
	)

	(title_block
		(title "41_5V_DC_DC - PACK_BUS to 5V_SYS conversion boundary")
		(date "2026-07-15")
		(rev "B0")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A/B: input protection, DC/DC, enable and primary diagnostics")
		(comment 2 "No controller, MOSFET, magnetics, capacitor, TVS, sensor or footprint selected")
	)
	(lib_symbols)
	(text "41_5V_DC_DC - PURPOSE\nConverts the separate PACK_BUS_P5_IN branch into 5V_SYS_BUS.\nPreliminary board budget is 15 A continuous / 20 A short peak.\nThis rail powers PCB-D outputs only; PCB-B critical rails remain independent."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.22 1.22)) (justify left))
		(uuid "power-5v-00000041-0000-4000-8000-000000000101")
	)
	(text "CONVERSION / INPUT ZONE\nFuture design must address input protection, reverse current, startup inrush, loop stability, ripple, transient response and EMI.\n5V_SYS_EN defaults OFF on lost control unless a later approved startup policy states otherwise.\nEfficiency and thermal limits require load profiles before component selection."
		(exclude_from_sim no)
		(at 12 78 0)
		(effects (font (size 1.12 1.12)) (justify left))
		(uuid "power-5v-00000041-0000-4000-8000-000000000102")
	)
	(text "DIAGNOSTICS / FAULT\nCanonical outputs are 5V_SYS_VSENSE, 5V_SYS_TOTAL_ISENSE and P5_DC_DC_FAULT_N for later board aggregation.\nRanges, accuracy, filtering, fault thresholds and restart policy remain TBD.\nConverter recovery must not override P5_GROUP_HARD_OFF."
		(exclude_from_sim no)
		(at 12 150 0)
		(effects (font (size 1.12 1.12)) (justify left))
		(uuid "power-5v-00000041-0000-4000-8000-000000000103")
	)

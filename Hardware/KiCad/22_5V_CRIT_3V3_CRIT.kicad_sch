	(paper "A3")
	(title_block
		(title "22_5V_CRIT_3V3_CRIT - critical-domain power conversion")
		(date "2026-07-15")
		(rev "B1")
		(company "Gonoboben/plataVM")
		(comment 1 "Interface consistency: KEEP_ALIVE_SOURCE feeds critical rail generation")
		(comment 2 "No DC/DC, LDO, supervisor, protection component, magnetics or footprint selected")
	)
	(lib_symbols)
	(text "22_5V_CRIT_3V3_CRIT - PURPOSE\nGenerates the critical-domain rails of PCB-B from KEEP_ALIVE_SOURCE.\nThe source-selection and charge/ORing boundary remains on 21_EMG_INPUT_CHARGE_ORING.\n5V_CRIT and 3V3_CRIT do not power external high-current loads."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.24 1.24)) (justify left))
		(uuid "ctrl-reserve-00000022-0000-4000-8000-000000000101")
	)
	(text "CRITICAL RAIL GENERATION\nFuture conversion stages must operate from the accepted KEEP_ALIVE_SOURCE range and tolerate transfer between PACK_BUS-derived and EMG-derived energy.\nTopology, efficiency target, ripple, inrush, sequencing and thermal design remain TBD.\nEach rail requires a defined safe state and monitored power-good/fault indication."
		(exclude_from_sim no)
		(at 12 74 0)
		(effects (font (size 1.16 1.16)) (justify left))
		(uuid "ctrl-reserve-00000022-0000-4000-8000-000000000102")
	)
	(text "GROUND / DOMAIN POLICY\nPOWER_GND is the reserve-source return; SIGNAL_GND is the local reference for MCU and low-level control.\nTheir connection point and filtering are not fixed on this sheet.\nISO_GND and CHASSIS remain outside this conversion boundary unless a later EMC decision explicitly connects them."
		(exclude_from_sim no)
		(at 12 144 0)
		(effects (font (size 1.16 1.16)) (justify left))
		(uuid "ctrl-reserve-00000022-0000-4000-8000-000000000103")
	)
	(text "FAULT RESPONSE\nCRIT_POWER_FAULT_N and CRIT_POWER_GOOD inform supervisor/fault-manager logic.\nA critical-rail fault may reset or contain the MCU, but it must not delay the independent EXT_KILL hardware chain.\nRecovery sequencing must not command automatic restart of K_BAT1 or K_BAT2."
		(exclude_from_sim no)
		(at 12 204 0)
		(effects (font (size 1.16 1.16)) (justify left))
		(uuid "ctrl-reserve-00000022-0000-4000-8000-000000000104")
	)
	(hierarchical_label "KEEP_ALIVE_SOURCE" (shape input) (exclude_from_sim no) (at 150 62 0) (effects (font (size 1.1 1.1)) (justify left)) (uuid "ctrl-reserve-00000022-0000-4000-8000-000000000201"))
	(hierarchical_label "POWER_GND" (shape passive) (exclude_from_sim no) (at 150 78 0) (effects (font (size 1.1 1.1)) (justify left)) (uuid "ctrl-reserve-00000022-0000-4000-8000-000000000203"))

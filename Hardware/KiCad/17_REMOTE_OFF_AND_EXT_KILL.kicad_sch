	(title_block
		(title "17_REMOTE_OFF_AND_EXT_KILL - hold-loop final actuators")
		(date "2026-07-15")
		(rev "B1")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level B: hold-loop return interruption and safe-state rules")
		(comment 2 "No relay/MOSFET/contact implementation selected")
	)
	(lib_symbols)
	(text "17_REMOTE_OFF_AND_EXT_KILL - LEVEL B HOLD-LOOP FUNCTION\nPin 11 from each SN-176A-12 is the K_BATx hold-loop return.\nEach battery keeps its own return loop: do not common BAT1 and BAT2 hold returns.\nOpening the loop de-energizes K_BATx coil; reclosing the loop does not restart the contactor.\nRestart requires LOCAL_STARTx in the external battery housing."
		(exclude_from_sim no)
		(at 12 16 0)
		(effects (font (size 1.35 1.35)) (justify left))
		(uuid "bfe-dh-00000017-0000-4000-8000-000000000101")
	)
	(text "LOGICAL CHAIN - BAT1\nBAT1_HOLD_RETURN_IN -> BAT1_EXT_KILL_NC -> BAT1_REMOTE_OFF_NC -> BAT1_SN176_NEG return.\nSeries order is functional; physical order may change if the safety analysis preserves fail-open behavior.\nBAT1_REMOTE_OFF_OPEN_CMD is a command to open the NC element, not a SET/RESET pulse."
		(exclude_from_sim no)
		(at 12 72 0)
		(effects (font (size 1.25 1.25)) (justify left))
		(uuid "bfe-dh-00000017-0000-4000-8000-000000000102")
	)
	(text "LOGICAL CHAIN - BAT2\nBAT2_HOLD_RETURN_IN -> BAT2_EXT_KILL_NC -> BAT2_REMOTE_OFF_NC -> BAT2_SN176_NEG return.\nThe two loops may share an EXT_KILL command source, but their battery returns must remain separated.\nEXT_KILL must not depend on MCU firmware or normal software execution."
		(exclude_from_sim no)
		(at 12 122 0)
		(effects (font (size 1.25 1.25)) (justify left))
		(uuid "bfe-dh-00000017-0000-4000-8000-000000000103")
	)
	(text "DIAGNOSTICS / OPEN ITEMS\nStatus feedback may verify NC element state and hold-loop continuity, but it must not become required for EXT_KILL action.\nNC actuator technology, driver energy, debouncing, fault detection and timing remain TBD.\nDo not convert pin 11 back into BMS telemetry, SET/RESET, CAN/RS-485 or UART."
		(exclude_from_sim no)
		(at 12 174 0)
		(effects (font (size 1.22 1.22)) (justify left))
		(uuid "bfe-dh-00000017-0000-4000-8000-000000000104")
	)

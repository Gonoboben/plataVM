		(title "17_REMOTE_OFF_AND_EXT_KILL - hold-loop final actuators")
		(date "2026-07-15")
		(rev "A1")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A: REMOTE_OFF_NC and EXT_KILL_NC boundary")
		(comment 2 "No relay/MOSFET/contact implementation selected")
	)
	(lib_symbols)
	(text "17_REMOTE_OFF_AND_EXT_KILL - FUNCTIONAL PURPOSE\nPin 11 from each SN-176A-12 is the K_BATx hold-loop return.\nREMOTE_OFF_NC and EXT_KILL_NC final elements interrupt this return path on PCB-A.\nOpening the loop de-energizes K_BATx coil; after reclosing, K_BATx remains OPEN until LOCAL_START is pressed again."
		(exclude_from_sim no)
		(at 12 18 0)
		(effects (font (size 1.45 1.45)) (justify left))
		(uuid "bfe-dh-00000017-0000-4000-8000-000000000101")
	)
	(text "PRIORITY RULES\nEXT_KILL must not depend on MCU firmware.\nREMOTE_OFF / EXT_KILL have priority over LOCAL_START.\nDisconnected or open hold-loop line must fail toward K_BATx OPEN.\nThis sheet is the final BFE-side actuator boundary; coil energy still comes from the protected battery side."
		(exclude_from_sim no)
		(at 12 84 0)
		(effects (font (size 1.35 1.35)) (justify left))
		(uuid "bfe-dh-00000017-0000-4000-8000-000000000102")
	)
	(text "OPEN ITEMS\nNC contact technology, actuation energy, driver topology, debounce, diagnostic feedback and timing remain TBD.\nDo not convert pin 11 back into a SET/RESET command or BMS telemetry line."
		(exclude_from_sim no)
		(at 12 148 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "bfe-dh-00000017-0000-4000-8000-000000000103")
	)

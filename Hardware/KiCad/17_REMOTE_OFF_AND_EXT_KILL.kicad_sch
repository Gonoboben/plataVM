	(lib_symbols)
	(text "17_REMOTE_OFF_AND_EXT_KILL - SYMBOL SKELETON PURPOSE\nThis sheet prepares future KiCad symbol placement for final hold-loop interruption elements on PCB-A.\nThe placeholders are logical zones, not selected components or footprints.\nThe upstream K_BATx coils remain inside the external battery housings and are not powered from PCB-A."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.28 1.28)) (justify left))
		(uuid "bfe-symbol-00000017-0000-4000-8000-000000000101")
	)
	(text "BAT1 HOLD-LOOP ACTUATOR SKELETON\nBAT1_HOLD_RETURN_IN -> K17A_BAT1_EXT_KILL_NC_TBD -> K17B_BAT1_REMOTE_OFF_NC_TBD -> BAT1_SN176_NEG.\nBAT1_HOLD_LOOP_OPEN_CMD is the normal remote-off request.\nBAT1_HOLD_LOOP_OPEN_HW and EXT_KILL_HW_CHAIN must open the loop without MCU firmware dependency."
		(exclude_from_sim no)
		(at 12 66 0)
		(effects (font (size 1.16 1.16)) (justify left))
		(uuid "bfe-symbol-00000017-0000-4000-8000-000000000102")
	)
	(text "BAT2 HOLD-LOOP ACTUATOR SKELETON\nBAT2_HOLD_RETURN_IN -> K17C_BAT2_EXT_KILL_NC_TBD -> K17D_BAT2_REMOTE_OFF_NC_TBD -> BAT2_SN176_NEG.\nBAT2_HOLD_LOOP_OPEN_CMD is the normal remote-off request.\nBAT2_HOLD_LOOP_OPEN_HW and EXT_KILL_HW_CHAIN must open the loop without MCU firmware dependency."
		(exclude_from_sim no)
		(at 12 128 0)
		(effects (font (size 1.16 1.16)) (justify left))
		(uuid "bfe-symbol-00000017-0000-4000-8000-000000000103")
	)
	(text "DIAGNOSTICS / TIMING PLACEHOLDERS\nDIAG_HOLD_LOOP_STATUS may monitor continuity and actuator state, but diagnostics must not be required for EXT_KILL action.\nFuture real symbols must preserve t_OFF >= max(250 ms; 5 x t_release_max) as a system requirement.\nDo not convert pin 11 into BMS telemetry, SET/RESET, CAN, RS-485 or UART."
		(exclude_from_sim no)
		(at 12 192 0)
		(effects (font (size 1.15 1.15)) (justify left))
		(uuid "bfe-symbol-00000017-0000-4000-8000-000000000104")
	)

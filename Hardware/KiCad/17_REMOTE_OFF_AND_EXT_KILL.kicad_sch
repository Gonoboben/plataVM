	(title_block
		(title "17_REMOTE_OFF_AND_EXT_KILL - fail-open run contacts and EXT_KILL")
		(date "2026-07-16")
		(rev "C3")
		(company "Gonoboben/plataVM")
		(comment 1 "V1.6 corrected physical semantics: energize-to-run NO REMOTE_OFF contacts")
		(comment 2 "Text-only placeholders; relay, EXT_KILL contact, suppression and diagnostics parts remain unselected")
	)
	(lib_symbols)
	(text "17_REMOTE_OFF_AND_EXT_KILL - V1.6 PURPOSE\nDefines the final PCB-A hold-loop interruption zones. K_BATx coils remain inside external battery housings.\nREMOTE_OFF uses an energize-to-run relay with a physical NO run-contact: healthy critical control closes it; loss of critical power opens it.\nEXT_KILL remains an independent series hardware path."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.22 1.22)) (justify left))
		(uuid "roff-v16-17-101")
	)
	(text "BAT1 HOLD LOOP\nBAT1_HOLD_RETURN_IN -> BAT1_EXT_KILL_NC_TBD -> BAT1_REMOTE_OFF_RUN_NO_TBD -> BAT1_SN176_NEG.\nBAT1_HOLD_LOOP_OPEN_CMD requests normal opening. BAT1_HOLD_LOOP_OPEN_HW and EXT_KILL_HW_CHAIN force opening without firmware dependency.\nRecovery cannot reclose K_BAT1 without a new LOCAL_START."
		(exclude_from_sim no)
		(at 12 72 0)
		(effects (font (size 1.08 1.08)) (justify left))
		(uuid "roff-v16-17-102")
	)
	(text "BAT2 HOLD LOOP\nBAT2_HOLD_RETURN_IN -> BAT2_EXT_KILL_NC_TBD -> BAT2_REMOTE_OFF_RUN_NO_TBD -> BAT2_SN176_NEG.\nBAT2_HOLD_LOOP_OPEN_CMD requests normal opening. BAT2_HOLD_LOOP_OPEN_HW and EXT_KILL_HW_CHAIN force opening without firmware dependency.\nThe two run contacts are independent, one per battery hold loop."
		(exclude_from_sim no)
		(at 12 138 0)
		(effects (font (size 1.08 1.08)) (justify left))
		(uuid "roff-v16-17-103")
	)
	(text "DIAGNOSTICS / TIMING\nDIAG_HOLD_LOOP_STATUS may monitor continuity and actuator state but is not required for EXT_KILL.\nRequired t_OFF >= max(250 ms; 5 x t_release_max); target system release <=100 ms.\nSuppression, relay DC rating and pin-11 fault injection remain open calculations/tests."
		(exclude_from_sim no)
		(at 12 206 0)
		(effects (font (size 1.08 1.08)) (justify left))
		(uuid "roff-v16-17-104")
	)

	(lib_symbols)
	(text "18_BATTERY_MEASUREMENTS - SYMBOL SKELETON ZONES\nThis sheet reserves text-only zones for later measurement frontend symbols.\nIt aggregates diagnostics from BAT1/BAT2, MAIN1/MAIN2, PACK_BUS, hold-loop and balance.\nNo assumption is made that BMS provides digital telemetry."
		(exclude_from_sim no)
		(at 12 16 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "bfe-lb-00000018-0000-4000-8000-000000000101")
	)
	(text "PLACEHOLDER ZONE: AFE18_BAT_INPUTS_TBD\nFuture voltage/current measurement frontend for BAT1_MEAS_TAPS and BAT2_MEAS_TAPS.\nDivider, shunt/Hall choice, protection, filtering, calibration and ground reference remain TBD."
		(exclude_from_sim no)
		(at 12 70 0)
		(effects (font (size 1.22 1.22)) (justify left))
		(uuid "bfe-lb-00000018-0000-4000-8000-000000000102")
	)
	(text "PLACEHOLDER ZONE: AFE18_MAIN_PATHS_TBD\nFuture diagnostics for MAIN_SW1 and MAIN_SW2 current, VIN, VOUT and fault state.\nMust preserve independent branch visibility for fault isolation."
		(exclude_from_sim no)
		(at 12 116 0)
		(effects (font (size 1.22 1.22)) (justify left))
		(uuid "bfe-lb-00000018-0000-4000-8000-000000000103")
	)
	(text "PLACEHOLDER ZONE: AFE18_SYSTEM_STATUS_TBD\nFuture PACK_BUS, hold-loop and balance diagnostics aggregation toward PCB-B_CTRL_RESERVE.\nDiagnostics shall not become required for EXT_KILL hardware action."
		(exclude_from_sim no)
		(at 12 162 0)
		(effects (font (size 1.22 1.22)) (justify left))
		(uuid "bfe-lb-00000018-0000-4000-8000-000000000104")
	)

	(lib_symbols)
	(text "18_BATTERY_MEASUREMENTS - LEVEL B GROUPS\nThis sheet aggregates measurement groups from BAT1/BAT2, MAIN_PATH_1/2, PACK_BUS, balance and hold-loop status.\nIt exports a logical diagnostic bundle to PCB-B_CTRL_RESERVE.\nBMS digital telemetry is not used."
		(exclude_from_sim no)
		(at 12 18 0)
		(effects (font (size 1.35 1.35)) (justify left))
		(uuid "bfe-lb-00000018-0000-4000-8000-000000000101")
	)
	(text "INPUT GROUPS\nBAT1_MEAS_TAPS / BAT2_MEAS_TAPS: voltage and presence taps from the battery input sheets.\nDIAG_MAINx_*: current, input voltage, output voltage and fault state from main paths.\nDIAG_PACK_BUS_*: PACK_BUS voltage and discharge state.\nDIAG_HOLD_LOOP_STATUS: K_BAT hold-loop final actuator status."
		(exclude_from_sim no)
		(at 12 82 0)
		(effects (font (size 1.25 1.25)) (justify left))
		(uuid "bfe-lb-00000018-0000-4000-8000-000000000102")
	)
	(text "OPEN ITEMS\nSense method, shunt/Hall selection, divider values, filtering, protection, sampling rate, calibration and ground reference remain TBD.\nMeasurement nets shall not create raw-cell access, BMS bypass, or hidden always-on loads."
		(exclude_from_sim no)
		(at 12 154 0)
		(effects (font (size 1.25 1.25)) (justify left))
		(uuid "bfe-lb-00000018-0000-4000-8000-000000000103")
	)

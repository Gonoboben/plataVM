	(lib_symbols)
	(text "18_BATTERY_MEASUREMENTS - SYMBOL SKELETON ZONES\nThis sheet reserves text-only zones for later measurement frontend symbols.\nIt aggregates diagnostics from BAT1/BAT2, MAIN1/MAIN2, PACK_BUS, hold-loop and balance.\nNo assumption is made that BMS provides digital telemetry."
		(exclude_from_sim no)
		(at 12 16 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "bfe-lb-00000018-0000-4000-8000-000000000101")
	)
	(text "PLACEHOLDER ZONE: AFE18_BAT_INPUTS_TBD\nFuture voltage/current/presence measurement frontend for BAT1_MEAS_TAPS and BAT2_MEAS_TAPS.\nBAT1_PRESENT_STATUS and BAT2_PRESENT_STATUS remain internal source-status names.\nCanonical external ports are BAT1/2_PRESENT, BAT1/2_VSENSE and BAT1/2_ISENSE."
		(exclude_from_sim no)
		(at 12 70 0)
		(effects (font (size 1.16 1.16)) (justify left))
		(uuid "bfe-lb-00000018-0000-4000-8000-000000000102")
	)
	(text "PLACEHOLDER ZONE: AFE18_MAIN_PATHS_TBD\nFuture diagnostics for MAIN_SW1 and MAIN_SW2 current, VIN, VOUT and fault state.\nBFE1_FAULT_N and BFE2_FAULT_N are canonical conditioned outputs; polarity conditioning remains TBD.\nIndependent branch visibility must be preserved."
		(exclude_from_sim no)
		(at 12 122 0)
		(effects (font (size 1.14 1.14)) (justify left))
		(uuid "bfe-lb-00000018-0000-4000-8000-000000000103")
	)
	(text "PLACEHOLDER ZONE: AFE18_SYSTEM_STATUS_TBD\nPACK_BUS_VSENSE, BALANCE1/2_FAULT_N and PACK_BUS_DISCHARGE_FAULT_N are canonical outputs toward PCB-B.\nDIAG_BALANCE_I, DIAG_BALANCE_TEMP, DIAG_BALANCE_STATUS and DIAG_HOLD_LOOP_STATUS remain internal observability inputs.\nDiagnostics are never required for EXT_KILL hardware action."
		(exclude_from_sim no)
		(at 12 174 0)
		(effects (font (size 1.12 1.12)) (justify left))
		(uuid "bfe-lb-00000018-0000-4000-8000-000000000104")
	)

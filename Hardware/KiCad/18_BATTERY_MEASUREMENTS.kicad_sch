	(lib_symbols)
	(text "18_BATTERY_MEASUREMENTS - FUNCTIONAL PURPOSE\nProvide BFE-side measurements for BAT1, BAT2, PACK_BUS, main paths, balance path and hold-loop status.\nDiagnostics are routed to PCB-B_CTRL_RESERVE.\nThis sheet defines measurement groups only; analog frontend, ADC, isolation and sensor components are TBD."
		(exclude_from_sim no)
		(at 12 18 0)
		(effects (font (size 1.45 1.45)) (justify left))
		(uuid "bfe-dh-00000018-0000-4000-8000-000000000101")
	)
	(text "MEASUREMENT GROUPS\n- BAT1/BAT2 voltage and branch current;\n- PACK_BUS voltage and discharge status;\n- MAIN_SWx current/fault/temperature TBD;\n- balance current/temperature TBD;\n- K_BATx auxiliary/open-closed state TBD."
		(exclude_from_sim no)
		(at 12 82 0)
		(effects (font (size 1.35 1.35)) (justify left))
		(uuid "bfe-dh-00000018-0000-4000-8000-000000000102")
	)
	(text "OPEN ITEMS\nSense method, divider values, shunt/Hall choice, filtering, protection, sampling rate, calibration and ground reference remain TBD.\nNo assumption that BMS provides digital telemetry."
		(exclude_from_sim no)
		(at 12 144 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "bfe-dh-00000018-0000-4000-8000-000000000103")
	)

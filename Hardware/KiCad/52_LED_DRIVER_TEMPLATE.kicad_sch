	(uuid "light-power-0000-4000-8000-000000000052")
	(paper "A3")
	(title_block
		(title "52_LED_DRIVER_TEMPLATE - single-channel functional contract")
		(date "2026-07-15")
		(rev "B0")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A/B: independent LED regulation, PWM, protection and diagnostics")
		(comment 2 "No boost/buck topology, controller, MOSFET, inductor, sensor, connector or footprint selected")
	)
	(lib_symbols)
	(text "52_LED_DRIVER_TEMPLATE - PURPOSE\nDefines the common functional contract for each of six independent LED channels.\nThe target external load class is one Epistar XY-J45 module per channel.\nElectrical operating limits shall be confirmed before any conversion topology or component is selected."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.18 1.18)) (justify left))
		(uuid "light-power-00000052-0000-4000-8000-000000000101")
	)
	(text "CONTROL / SAFE STATE\nLIGHT_BRANCH_EN provides group permission; LED_PWM provides channel-specific modulation.\nLIGHT_GROUP_HARD_OFF overrides both signals and forces the channel OFF.\nUnpowered control, reset, lost firmware and disconnected-control states must resolve to LED output OFF."
		(exclude_from_sim no)
		(at 12 76 0)
		(effects (font (size 1.10 1.10)) (justify left))
		(uuid "light-power-00000052-0000-4000-8000-000000000102")
	)
	(text "POWER / REGULATION / PROTECTION\nFuture channel design must regulate LED current across the accepted PACK_BUS and LED-voltage range.\nOpen-load, shorted-load, overcurrent, overvoltage, thermal and reverse/backfeed behavior remain TBD.\nNo assumption is made here that the final topology is boost, buck, buck-boost, SEPIC or another class."
		(exclude_from_sim no)
		(at 12 138 0)
		(effects (font (size 1.08 1.08)) (justify left))
		(uuid "light-power-00000052-0000-4000-8000-000000000103")
	)
	(text "DIAGNOSTIC CONTRACT\nEach channel provides LED_FAULT_N and LED_ISENSE while retaining channel identity.\nOptional open/short subtype and local temperature/status may be added after topology selection.\nDiagnostic transport, ranges, accuracy and fault-latch/retry policy remain TBD."
		(exclude_from_sim no)
		(at 12 210 0)
		(effects (font (size 1.10 1.10)) (justify left))
		(uuid "light-power-00000052-0000-4000-8000-000000000104")
	)

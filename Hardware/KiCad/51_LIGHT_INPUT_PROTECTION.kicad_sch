		(date "2026-07-15")
		(rev "B0")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A/B: input protection, bulk energy and input diagnostics")
		(comment 2 "No fuse, eFuse, TVS, reverse protection, capacitor, connector or footprint selected")
	)
	(lib_symbols)
	(text "51_LIGHT_INPUT_PROTECTION - PURPOSE\nDefines the PCB-E power-entry boundary from PCB-A.\nPACK_BUS_LIGHT_IN and POWER_GND enter through the independent star-distributed light branch.\nNo lighting power passes through PCB-B."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.22 1.22)) (justify left))
		(uuid "light-power-00000051-0000-4000-8000-000000000101")
	)
	(text "INPUT PROTECTION / INRUSH\nFuture design must address branch overcurrent, reverse connection/current, transients and aggregate driver startup inrush.\nBulk capacitance, damping, precharge/inrush and discharge timing remain TBD.\nA branch fault shall not defeat PCB-A, PCB-C or PCB-D operation."
		(exclude_from_sim no)
		(at 12 76 0)
		(effects (font (size 1.12 1.12)) (justify left))
		(uuid "light-power-00000051-0000-4000-8000-000000000102")
	)
	(text "INPUT DIAGNOSTICS\nLIGHT_INPUT_VSENSE is the canonical input-voltage observation.\nLIGHT_INPUT_FAULT_N and LIGHT_INPUT_PRESENT are local conditioned placeholders for board-fault aggregation.\nRanges, thresholds, filtering and reference method remain TBD."
		(exclude_from_sim no)
		(at 12 146 0)
		(effects (font (size 1.12 1.12)) (justify left))
		(uuid "light-power-00000051-0000-4000-8000-000000000103")
	)

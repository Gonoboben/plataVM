		(title "54_LED_DRIVER_4_6 - independent driver zone 2")
		(date "2026-07-15")
		(rev "B0")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A/B: LED channels 4..6 in one local thermal/power zone")
		(comment 2 "Symmetric to 53; no topology, components, thermal hardware, connector or footprint selected")
	)
	(lib_symbols)
	(text "54_LED_DRIVER_4_6 - PURPOSE\nDefines three independent channel instances based on sheet 52.\nChannels retain independent PWM, current regulation, output and diagnostic identities.\nThis grouping is a local PCB-E zone only and remains symmetric with channels 1..3."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.18 1.18)) (justify left))
		(uuid "light-power-00000054-0000-4000-8000-000000000101")
	)
	(text "CONTROL / SAFE STATE\nLED_PWM_4_6 represents three independent PWM controls.\nLIGHT_BRANCH_EN permits normal operation and LIGHT_GROUP_HARD_OFF overrides every channel.\nDefault state for all three outputs is OFF."
		(exclude_from_sim no)
		(at 12 78 0)
		(effects (font (size 1.10 1.10)) (justify left))
		(uuid "light-power-00000054-0000-4000-8000-000000000102")
	)
	(text "POWER / THERMAL / DIAGNOSTICS\nAll channels draw from LIGHT_PROTECTED_BUS while remaining electrically independent.\nLED_FAULT_N_4_6 and LED_ISENSE_4_6 preserve channel identity.\nShared copper, thermal spreading and zone-temperature sensing require later loss and layout calculations."
		(exclude_from_sim no)
		(at 12 142 0)
		(effects (font (size 1.08 1.08)) (justify left))
		(uuid "light-power-00000054-0000-4000-8000-000000000103")
	)

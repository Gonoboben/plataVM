	(title_block
		(title "29_CTRL_CONNECTORS_TESTPOINTS - connector, CAN-FD and ground boundary")
		(date "2026-07-16")
		(rev "C1")
		(company "Gonoboben/plataVM")
		(comment 1 "V1.6 connector groups include internal CAN-FD, direct safety/fault lines and one ground net-tie")
		(comment 2 "No connector family, pinout, cable, termination part, net-tie part or footprint selected")
	)
	(lib_symbols)
	(text "29_CTRL_CONNECTORS_TESTPOINTS - PURPOSE\nGroups PCB-B physical-interface classes without selecting connectors or pins.\nPower, direct critical control, internal CAN-FD, hardware safety/fault, external isolated RS-485, EXT_KILL and service remain separate.\nSignal connector reserve target is 20-30 percent."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.22 1.22)) (justify left))
		(uuid "conn-v16-29-101")
	)
	(text "INTERBOARD GROUPS\nPWR_A_TO_B_CRIT carries only the limited critical branch. PCB-A direct control/diagnostics remain separate.\nCAN_INT_H/L carries normal PCB-C/D/E traffic. Direct SAFE/HARD_OFF and board-fault summary lines use dedicated contacts and returns.\nHigh-current load power does not pass through PCB-B."
		(exclude_from_sim no)
		(at 12 72 0)
		(effects (font (size 1.10 1.10)) (justify left))
		(uuid "conn-v16-29-102")
	)
	(text "GROUND / SHIELD BOUNDARY\nSIGNAL_GND and POWER_GND connect at one controlled NET_TIE_GND_B point only.\nISO_GND remains DC-isolated. Cable shields connect to CHASSIS at entry.\nCAN termination location and common-mode/ESD network follow final physical node order."
		(exclude_from_sim no)
		(at 12 142 0)
		(effects (font (size 1.10 1.10)) (justify left))
		(uuid "conn-v16-29-103")
	)
	(text "EXTERNAL / SERVICE / TEST POLICY\nRS485_ISOLATED is the external communication group; EXT_KILL_IN_RAW is the independent emergency input.\nEMG_4S2P_EXTERNAL and SERVICE_DEBUG remain separate. Testpoints are low-energy observation points only and must not bridge ground domains or expose unprotected PACK_BUS."
		(exclude_from_sim no)
		(at 12 204 0)
		(effects (font (size 1.08 1.08)) (justify left))
		(uuid "conn-v16-29-104")
	)

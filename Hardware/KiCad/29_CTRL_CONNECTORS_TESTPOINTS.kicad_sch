	(title_block
		(title "29_CTRL_CONNECTORS_TESTPOINTS - logical connector and test boundary")
		(date "2026-07-15")
		(rev "B1")
		(company "Gonoboben/plataVM")
		(comment 1 "Interface consistency: canonical RS485_ISOLATED and EXT_KILL_IN_RAW groups")
		(comment 2 "No connector family, pin count, pinout, cable, testpoint technology or footprint selected")
	)
	(lib_symbols)
	(text "29_CTRL_CONNECTORS_TESTPOINTS - PURPOSE\nGroups PCB-B logical interfaces for later connector and testpoint design.\nThis sheet does not create physical connectors, assign pins or choose footprints.\nPower, safety, normal control, diagnostics, communication and service classes remain separated."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.28 1.28)) (justify left))
		(uuid "ctrl-reserve-00000029-0000-4000-8000-000000000101")
	)
	(text "INTERBOARD GROUPS\nPWR_A_TO_B_CRIT carries PACK_BUS_CRIT_IN and POWER_GND only for the limited critical branch.\nCTRL_B_TO_A / DIAG_A_TO_B connect PCB-B with PCB-A; equivalent grouped boundaries exist for PCB-C/D/E.\nHigh-current load power does not pass through PCB-B or through these signal groups."
		(exclude_from_sim no)
		(at 12 72 0)
		(effects (font (size 1.16 1.16)) (justify left))
		(uuid "ctrl-reserve-00000029-0000-4000-8000-000000000102")
	)
	(text "EXTERNAL / SAFETY / SERVICE GROUPS\nRS485_ISOLATED is the external isolated communication group and EXT_KILL_IN_RAW is the external emergency input boundary.\nEMG_4S2P_EXTERNAL and SERVICE_DEBUG remain separate interface classes.\nDisconnect behavior and safety-return implementation require later electrical and mechanical review."
		(exclude_from_sim no)
		(at 12 138 0)
		(effects (font (size 1.14 1.14)) (justify left))
		(uuid "ctrl-reserve-00000029-0000-4000-8000-000000000103")
	)
	(text "TESTPOINT POLICY\nLow-energy testpoints may observe critical rails, reset, fault latches and communication status.\nNo testpoint may expose an unprotected high-current PACK_BUS path or bridge POWER_GND, SIGNAL_GND, ISO_GND and CHASSIS.\nFinal testpoint ratings, guarding and access restrictions remain TBD."
		(exclude_from_sim no)
		(at 12 204 0)
		(effects (font (size 1.16 1.16)) (justify left))
		(uuid "ctrl-reserve-00000029-0000-4000-8000-000000000104")
	)

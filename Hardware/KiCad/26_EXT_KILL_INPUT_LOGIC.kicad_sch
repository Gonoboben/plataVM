	(title_block
		(title "26_EXT_KILL_INPUT_LOGIC - independent emergency shutdown chain")
		(date "2026-07-15")
		(rev "B0")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A/B: external EXT_KILL boundary, latch and hardware fanout")
		(comment 2 "Text-only placeholders; no switch, relay, optocoupler, comparator, latch, connector or footprint selected")
	)
	(lib_symbols)
	(text "26_EXT_KILL_INPUT_LOGIC - PURPOSE\nDefines the independent hardware handling of the external EXT_KILL input on PCB-B.\nThe active event must propagate to PCB-A final actuators without MCU firmware, RS-485 or normal control power dependency.\nREMOTE_OFF and EXT_KILL retain priority over LOCAL_START."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.28 1.28)) (justify left))
		(uuid "ctrl-reserve-00000026-0000-4000-8000-000000000101")
	)
	(text "INPUT BOUNDARY / FAIL-SAFE POLICY\nEXT_KILL_IN_RAW is a logical external boundary; contact topology, active level, line supervision and cable protection remain TBD.\nDisconnect, short, loss of PCB-B normal control and brownout behavior must be explicitly resolved in the next electrical pass.\nThe chosen implementation shall fail toward safe shutdown for credible single faults."
		(exclude_from_sim no)
		(at 12 76 0)
		(effects (font (size 1.16 1.16)) (justify left))
		(uuid "ctrl-reserve-00000026-0000-4000-8000-000000000102")
	)
	(text "HARDWARE LATCH / FANOUT\nEXT_KILL_HW_CHAIN is the aggregate hardware output toward PCB-A.\nThe chain must command BAT1/2 hold-loop opening and MAIN_SW1/2 off independently of firmware.\nEXT_KILL_LATCHED prevents automatic restart until an authorized manual reset condition is satisfied."
		(exclude_from_sim no)
		(at 12 142 0)
		(effects (font (size 1.16 1.16)) (justify left))
		(uuid "ctrl-reserve-00000026-0000-4000-8000-000000000103")
	)
	(text "OBSERVATION ONLY\nEXT_KILL_EVENT_STATUS is provided to MCU/fault manager only for logging and status reporting.\nMCU may not mask, clear or delay the hardware outputs.\nService/debug access must not bypass the latch or force final actuators back on."
		(exclude_from_sim no)
		(at 12 208 0)
		(effects (font (size 1.16 1.16)) (justify left))
		(uuid "ctrl-reserve-00000026-0000-4000-8000-000000000104")
	)

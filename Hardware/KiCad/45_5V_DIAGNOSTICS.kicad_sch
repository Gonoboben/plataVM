	(title_block
		(title "45_5V_DIAGNOSTICS - output and 5V_SYS diagnostics")
		(date "2026-07-15")
		(rev "B0")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A/B: ten-output and converter diagnostic aggregation")
		(comment 2 "No ADC, mux, local controller, sensor, serializer, isolator or footprint selected")
	)
	(lib_symbols)
	(text "45_5V_DIAGNOSTICS - PURPOSE\nAggregates ten output diagnostic pairs and 5V_SYS converter observations toward PCB-B.\nChannel identity is preserved; physical parallel/muxed/serialized transport remains TBD.\nDiagnostics cannot block or delay group HARD_OFF."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.20 1.20)) (justify left))
		(uuid "power-5v-00000045-0000-4000-8000-000000000101")
	)
	(text "CANONICAL DIAGNOSTICS\nP5_OUT_FAULT_N[1..10] and P5_OUT_ISENSE[1..10] retain output identity.\n5V_SYS_VSENSE and 5V_SYS_TOTAL_ISENSE describe the common converter rail.\nP5_BOARD_TEMP and P5_BOARD_FAULT_N provide board-level observation and conditioned fault summary."
		(exclude_from_sim no)
		(at 12 78 0)
		(effects (font (size 1.10 1.10)) (justify left))
		(uuid "power-5v-00000045-0000-4000-8000-000000000102")
	)
	(text "FAULT AGGREGATION\nP5_BOARD_FAULT_N may combine converter, thermal and critical output faults but must not hide individual P5_OUT_FAULT_N bits.\nThresholds, latching, debounce, calibration and reset behavior remain TBD."
		(exclude_from_sim no)
		(at 12 144 0)
		(effects (font (size 1.12 1.12)) (justify left))
		(uuid "power-5v-00000045-0000-4000-8000-000000000103")
	)

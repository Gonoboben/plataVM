	(title_block
		(title "20_CTRL_RESERVE_TOP - PCB-B_CTRL_RESERVE")
		(date "2026-07-15")
		(rev "A1")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A: MCU, critical power, EMG, RS-485, control IO")
		(comment 2 "No MCU/DC-DC/transceiver part numbers selected")
	)
	(lib_symbols)
	(text "20_CTRL_RESERVE_TOP - PCB-B_CTRL_RESERVE\nPurpose: define control, critical power, EMG and communication functional zones.\nHigh-current load power must not pass through PCB-B."
		(exclude_from_sim no)
		(at 12 10 0)
		(effects (font (size 1.55 1.55)) (justify left))
		(uuid "ctrl-b-text-0001")
	)
	(text "CRITICAL POWER / EMG\nPACK_BUS_CRIT_IN feeds reserve/critical power only.\nEMG / KEEP_ALIVE sustains MCU logging and controlled shutdown.\nEMG must not power heavy external loads."
		(exclude_from_sim no)
		(at 12 38 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "ctrl-b-text-0002")
	)
	(text "MCU / FAULT MANAGER\nMCU supervises normal control, diagnostics and logging.\nWatchdog/supervisor provides reset and fault containment.\nSafety-critical EXT_KILL path has hardware priority over firmware."
		(exclude_from_sim no)
		(at 112 38 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "ctrl-b-text-0003")
	)
	(text "COMMUNICATIONS\nIsolated RS-485 is the active external communication interface.\nOptional CAN/CAN-FD footprints may remain DNP only.\nISO_GND remains separate from POWER_GND/SIGNAL_GND until EMC decision."
		(exclude_from_sim no)
		(at 222 38 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "ctrl-b-text-0004")
	)
	(text "CONTROL OUTPUTS\nTo PCB-A: MAIN_SWx, BALANCE_SWx, hold-loop open, discharge, EXT_KILL chain.\nTo PCB-C/D/E: channel enables, group safe-off, PWM and reset lines.\nParallel vs serialized control remains TBD."
		(exclude_from_sim no)
		(at 12 112 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "ctrl-b-text-0005")
	)
	(text "DIAGNOSTIC INPUTS\nFrom PCB-A: battery/pack measurements and BFE faults.\nFrom PCB-C/D/E: channel current, voltage, fault, status and temperatures.\nMuxed analog, SPI/I2C or parallel topology remains TBD."
		(exclude_from_sim no)
		(at 112 112 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "ctrl-b-text-0006")
	)
	(text "SERVICE / DEBUG\nSWD/debug and service UART are internal/service only.\nDebug access must not bypass EXT_KILL/HARD_OFF.\nBoot/config straps and programming connector family are TBD."
		(exclude_from_sim no)
		(at 222 112 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "ctrl-b-text-0007")
	)
	(text "GROUND / SAFETY RULES\nPOWER_GND, SIGNAL_GND, ISO_GND and CHASSIS are not automatically shorted.\nEXT_KILL input must propagate to final actuators without depending on MCU code.\nCritical power must support orderly logging after HARD_OFF."
		(exclude_from_sim no)
		(at 12 190 0)
		(effects (font (size 1.25 1.25)) (justify left))
		(uuid "ctrl-b-text-0008")
	)

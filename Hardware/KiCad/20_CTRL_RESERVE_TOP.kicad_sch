	(title_block
		(title "20_CTRL_RESERVE_TOP - PCB-B_CTRL_RESERVE")
		(date "2026-07-15")
		(rev "A3")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A/B: PCB-B detailed hierarchy map with preserved external interfaces")
		(comment 2 "Sub-sheets 21..29 define functional boundaries only; no components selected")
	)
	(lib_symbols)
	(text "SUB-SHEETS 21..24\n21_EMG_INPUT_CHARGE_ORING: PACK_BUS critical input, EMG source, charge/ORing and KEEP_ALIVE\n22_5V_CRIT_3V3_CRIT: critical-domain rail generation and monitored power-good/fault\n23_MCU_CORE: normal control, logging and logical interface ownership\n24_WATCHDOG_SUPERVISOR: reset, supervisor, fault manager and safe-state containment"
		(exclude_from_sim no)
		(at 12 78 0)
		(effects
			(font
				(size 1.22 1.22)
			)
			(justify left)
		)
		(uuid "29e3c7aa-8840-4b43-85f4-2f2021b06dcd")
	)
	(text "ARCHITECTURAL CONSTRAINTS\n- no K_MAIN; PACK_BUS is created and distributed from PCB-A;\n- only the limited PACK_BUS_CRIT_IN branch enters PCB-B;\n- EXT_KILL propagates to PCB-A final actuators without MCU firmware or RS-485 dependency;\n- REMOTE_OFF and EXT_KILL retain priority over LOCAL_START;\n- BMS or critical-power recovery must not automatically energize K_BAT1/K_BAT2;\n- POWER_GND, SIGNAL_GND, ISO_GND and CHASSIS remain distinct until an explicit decision."
		(exclude_from_sim no)
		(at 12 160 0)
		(effects
			(font
				(size 1.16 1.16)
			)
			(justify left)
		)
		(uuid "5251d60d-4bff-4773-a236-051a6c6b8f1b")
	)
	(text "SUB-SHEETS 25..29\n25_RS485_ISOLATED: external half-duplex isolated communication\n26_EXT_KILL_INPUT_LOGIC: independent input, latch and hardware fanout\n27_CONTROL_IO: PCB-A/C/D/E commands and diagnostic groups\n28_SERVICE_DEBUG: SWD, service UART and authorized reset boundary\n29_CTRL_CONNECTORS_TESTPOINTS: logical connector classes and controlled testpoints"
		(exclude_from_sim no)
		(at 168 78 0)
		(effects
			(font
				(size 1.22 1.22)
			)
			(justify left)
		)
		(uuid "8444a4f7-00c2-4a0e-8046-bd68713c9cb8")
	)
	(text "NEXT CONTROLLED PASS\nCheck exact PCB-B interface names against PCB-A and 02_INTERBOARD_POWER_AND_CONTROL.\nThen add text-only symbol skeleton zones or real topologies only through a separate explicit stage.\nMCU, converters, isolation, transceiver, watchdog, connectors, footprints, BOM and layout remain intentionally unselected."
		(exclude_from_sim no)
		(at 12 220 0)
		(effects
			(font
				(size 1.12 1.12)
			)
			(justify left)
		)
		(uuid "9fb7de2a-193f-43dc-89c9-52349654521f")
	)
	(text "20_CTRL_RESERVE_TOP - DETAILED HIERARCHY MAP\nPCB-B_CTRL_RESERVE contains the limited critical/reserve power branch, EMG/KEEP_ALIVE,\nMCU, watchdog/supervisor/fault manager, isolated RS-485, control/diagnostic I/O,\nindependent EXT_KILL handling and controlled service/debug boundaries.\nHigh-current load power must not pass through PCB-B."
		(exclude_from_sim no)
		(at 12 12 0)
		(effects
			(font
				(size 1.45 1.45)
			)
			(justify left)
		)
		(uuid "d0b089a6-22a7-409d-9871-adcb32d41011")
	)

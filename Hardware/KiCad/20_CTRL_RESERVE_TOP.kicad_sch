		(title "20_CTRL_RESERVE_TOP - PCB-B_CTRL_RESERVE")
		(date "2026-07-16")
		(rev "A4")
		(company "Gonoboben/plataVM")
		(comment 1 "V1.6 PCB-B boundary: STM32G4 family, internal CAN-FD and direct hardware safety")
		(comment 2 "Functional hierarchy only; no components, connectors, footprints or layout selected")
	)
	(lib_symbols)
	(text "20_CTRL_RESERVE_TOP - V1.6 HIERARCHY MAP\nPCB-B contains critical/reserve power, EMG/KEEP_ALIVE, central MCU, watchdog/supervisor, fault manager, external isolated RS-485, internal CAN-FD and direct hardware safety I/O.\nHigh-current load power does not pass through PCB-B."
		(exclude_from_sim no)
		(at 12 12 0)
		(effects (font (size 1.36 1.36)) (justify left))
		(uuid "pcb-b-v16-20-101")
	)
	(text "SUB-SHEETS 21..24\n21: EMG input/charge/ORing and KEEP_ALIVE\n22: 5V_CRIT / 3V3_CRIT\n23: STM32G4-family MCU core and communication ownership\n24: watchdog, supervisor and fault containment"
		(exclude_from_sim no)
		(at 12 78 0)
		(effects (font (size 1.15 1.15)) (justify left))
		(uuid "pcb-b-v16-20-102")
	)
	(text "SUB-SHEETS 25..29\n25: external isolated RS-485\n26: independent EXT_KILL input logic\n27: direct safety/fault I/O and CAN-FD data-object boundary\n28: service/debug\n29: connector/testpoint, CAN-FD and ground net-tie boundaries"
		(exclude_from_sim no)
		(at 166 78 0)
		(effects (font (size 1.15 1.15)) (justify left))
		(uuid "pcb-b-v16-20-103")
	)
	(text "INTERBOARD POLICY\nPCB-A critical control/measurements remain direct.\nPCB-C/D/E normal commands and telemetry use CAN_INT_H/L.\nP12/P5 SAFE/HARD_OFF, LIGHT HARD_OFF and board-fault summaries remain direct hardware lines.\nExternal RS-485 is not the internal bus."
		(exclude_from_sim no)
		(at 12 154 0)
		(effects (font (size 1.10 1.10)) (justify left))
		(uuid "pcb-b-v16-20-104")
	)
	(text "GROUND / FAIL-SAFE POLICY\nOne controlled SIGNAL_GND-POWER_GND net-tie point exists on PCB-B. ISO_GND remains DC-isolated and shields terminate to CHASSIS at entry.\nLoss of healthy critical power opens energize-to-run REMOTE_OFF run contacts. EXT_KILL remains independent of MCU and CAN-FD."
		(exclude_from_sim no)
		(at 12 218 0)
		(effects (font (size 1.08 1.08)) (justify left))
		(uuid "pcb-b-v16-20-105")
	)

		(title "43_5V_OUT1_OUT5 - controlled output group")
		(date "2026-07-15")
		(rev "B0")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A/B: five independent controlled 5 V outputs")
		(comment 2 "No load switch, protection, sensor, connector or footprint selected")
	)
	(lib_symbols)
	(text "43_5V_OUT1_OUT5 - PURPOSE\nDefines five independent output instances based on sheet 42.\nEach output has its own normal enable, protection boundary, power output and diagnostic pair.\nThe group shares 5V_SYS_BUS and group SAFE/HARD_OFF only."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.20 1.20)) (justify left))
		(uuid "power-5v-00000043-0000-4000-8000-000000000101")
	)
	(text "CONTROLLED OUTPUTS 1..5\nP5_OUT_EN_1_5 represents five independent normal-control enables.\nP5_GROUP_SAFE_OFF and P5_GROUP_HARD_OFF override all enables.\nA single output fault should remain contained without destabilizing 5V_SYS_BUS."
		(exclude_from_sim no)
		(at 12 78 0)
		(effects (font (size 1.12 1.12)) (justify left))
		(uuid "power-5v-00000043-0000-4000-8000-000000000102")
	)
	(text "POWER / DIAGNOSTICS\nThe group preserves output identity as 5V_OUTPUTS_1_5 and diagnostic identity as P5_OUT_FAULT_N_1_5 / P5_OUT_ISENSE_1_5.\nSimultaneous-load, copper and thermal limits remain governed by the total 5V_SYS budget."
		(exclude_from_sim no)
		(at 12 144 0)
		(effects (font (size 1.12 1.12)) (justify left))
		(uuid "power-5v-00000043-0000-4000-8000-000000000103")
	)

	(paper "A3")
	(title_block
		(title "11_BATTERY_INPUT_1 - BFE input from AKB_1")
		(date "2026-07-15")
		(rev "A1")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A: BFE-side input boundary for battery 1")
		(comment 2 "No connector family, fuse, current sensor or contactor model selected here")
	)
	(lib_symbols)
	(text "11_BATTERY_INPUT_1 - FUNCTIONAL BOUNDARY\nInput comes from AKB_1 external housing through SN-176A-12 after BMS, fuse and K_BAT1.\nPins 1..5 = BAT1+, pins 6..10 = BAT1-, pin 11 = BAT1_REMOTE_OFF / K_BAT1_HOLD_RETURN, pin 12 = reserve.\nLOCAL_START1 is a separate two-pin momentary NO connector and does not pass through SN-176A-12."
		(exclude_from_sim no)
		(at 12 18 0)
		(effects (font (size 1.45 1.45)) (justify left))
		(uuid "bfe-dh-00000011-0000-4000-8000-000000000101")
	)
	(text "BFE-SIDE FUNCTIONS\n- route BAT1 power into the BFE_1 branch;\n- provide measurement access for BAT1 voltage/current path;\n- route REMOTE_OFF loop return to final NC actuator on PCB-A;\n- preserve symmetry with 12_BATTERY_INPUT_2."
		(exclude_from_sim no)
		(at 12 78 0)
		(effects (font (size 1.35 1.35)) (justify left))
		(uuid "bfe-dh-00000011-0000-4000-8000-000000000102")
	)
	(text "SAFETY RULES\nNo raw cell branch, no BMS digital telemetry, no assumption about high-side/low-side BMS switching.\nIf pin 11 / REMOTE_OFF loop is open, K_BAT1 must not remain energized.\nBMS recovery must not cause automatic restart."
		(exclude_from_sim no)
		(at 12 136 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "bfe-dh-00000011-0000-4000-8000-000000000103")
	)
	(hierarchical_label "BAT1_SN176_POWER_IN" (shape passive) (exclude_from_sim no) (at 120 56 0) (effects (font (size 1.15 1.15)) (justify left)) (uuid "bfe-dh-00000011-0000-4000-8000-000000000201"))
	(hierarchical_label "BAT1_REMOTE_OFF_LOOP_IN" (shape passive) (exclude_from_sim no) (at 120 66 0) (effects (font (size 1.15 1.15)) (justify left)) (uuid "bfe-dh-00000011-0000-4000-8000-000000000202"))
	(hierarchical_label "BAT1_TO_MAIN_PATH" (shape passive) (exclude_from_sim no) (at 120 102 0) (effects (font (size 1.15 1.15)) (justify left)) (uuid "bfe-dh-00000011-0000-4000-8000-000000000203"))
	(hierarchical_label "BAT1_MEAS_TAPS" (shape passive) (exclude_from_sim no) (at 120 112 0) (effects (font (size 1.15 1.15)) (justify left)) (uuid "bfe-dh-00000011-0000-4000-8000-000000000204"))

	(lib_symbols)
	(text "11_BATTERY_INPUT_1 - SYMBOL SKELETON PURPOSE\nThis sheet prepares future KiCad symbol placement for the BAT1 external connector boundary.\nJ_BAT1_SN176_TBD is a future 12-pin connector placeholder for the mating side of SN-176A-12.\nNo physical connector family, footprint, pin hardware, cable section or manufacturer part number is selected here."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.28 1.28)) (justify left))
		(uuid "bfe-symbol-00000011-0000-4000-8000-000000000101")
	)
	(text "J_BAT1_SN176_TBD PIN GROUPING\nPins 1..5  -> BAT1_SN176_POS.\nPins 6..10 -> BAT1_SN176_NEG / protected return.\nPin 11     -> BAT1_HOLD_RETURN_IN.\nPin 12     -> BAT1_SN176_RESERVE, unassigned until explicitly approved.\nLOCAL_START1 remains a separate two-pin momentary NO connector inside the external battery housing. It is not routed through PCB-A."
		(exclude_from_sim no)
		(at 12 62 0)
		(effects (font (size 1.20 1.20)) (justify left))
		(uuid "bfe-symbol-00000011-0000-4000-8000-000000000102")
	)
	(text "POWER / MEASUREMENT / BALANCE BOUNDARY\nBAT1_SN176_POS and BAT1_SN176_NEG feed BFE_1 only and then continue as BAT1_TO_MAIN_PATH.\nBAT1_MEAS_TAPS and BAT1_PRESENT_STATUS are routed to 18_BATTERY_MEASUREMENTS.\nBALANCE_TAP_BAT1 is the controlled deck-balance tap source for 15_DECK_BALANCE.\nDo not assume BMS internal high-side or low-side topology; use only the external protected pair."
		(exclude_from_sim no)
		(at 12 126 0)
		(effects (font (size 1.18 1.18)) (justify left))
		(uuid "bfe-symbol-00000011-0000-4000-8000-000000000103")
	)
	(text "HOLD-LOOP / SAFE STATE\nBAT1_HOLD_RETURN_IN from pin 11 is routed to 17_REMOTE_OFF_AND_EXT_KILL.\nIf this loop is open, K_BAT1 must release or remain OPEN.\nBMS recovery must not restart K_BAT1 without LOCAL_START1.\nFuture real connector symbol shall preserve these net names exactly."
		(exclude_from_sim no)
		(at 12 194 0)
		(effects (font (size 1.16 1.16)) (justify left))
		(uuid "bfe-symbol-00000011-0000-4000-8000-000000000104")
	)

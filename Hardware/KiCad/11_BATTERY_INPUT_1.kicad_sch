	(hierarchical_label "BAT1_SN176_NEG" (shape passive) (exclude_from_sim no) (at 138 52 0) (effects (font (size 1.1 1.1)) (justify left)) (uuid "bfe-symbol-00000011-0000-4000-8000-000000000202"))

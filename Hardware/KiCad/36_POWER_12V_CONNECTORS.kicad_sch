		(title "36_POWER_12V_CONNECTORS - logical output and harness boundary")
		(date "2026-07-15")
		(rev "B0")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A/B: CH1..CH14 output/return grouping and test boundaries")
		(comment 2 "No connector family, pin count, wire gauge, cable, testpoint or footprint selected")
	)
	(lib_symbols)
	(text "36_POWER_12V_CONNECTORS - PURPOSE\nGroups the fourteen protected outputs and their returns for later harness and connector design.\nThis sheet does not assign physical pins, combine independent channels or select connector technology.\nHigh-current output conductors and returns remain outside PCB-B."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.22 1.22)) (justify left))
		(uuid "power-12v-00000036-0000-4000-8000-000000000101")
	)
	(text "OUTPUT GROUPING\nP12_OUTPUTS_CH1_7 and P12_OUTPUTS_CH8_14 combine only as the logical group P12_OUTPUTS_CH1_14.\nEach channel must retain an individually identifiable positive conductor and correctly sized return path.\nShared-return topology is not approved by this sheet and requires current/voltage-drop/fault analysis."
		(exclude_from_sim no)
		(at 12 76 0)
		(effects (font (size 1.10 1.10)) (justify left))
		(uuid "power-12v-00000036-0000-4000-8000-000000000102")
	)
	(text "CONNECTOR / HARNESS REQUIREMENTS TBD\nBefore selection, define per-channel load, inrush, duty cycle, wire length, allowable drop, environmental sealing, vibration, mating cycles and wrong-mate prevention.\nReturn conductors, shielding and chassis treatment must follow the later ground/harness decision."
		(exclude_from_sim no)
		(at 12 142 0)
		(effects (font (size 1.10 1.10)) (justify left))
		(uuid "power-12v-00000036-0000-4000-8000-000000000103")
	)
	(text "TEST / SERVICE POLICY\nLow-energy diagnostic testpoints may observe enables, faults and conditioned sense signals.\nPower testpoints require guarding, short-circuit protection and access control.\nNo testpoint may bypass per-channel protection or connect output channels together."
		(exclude_from_sim no)
		(at 12 208 0)
		(effects (font (size 1.12 1.12)) (justify left))
		(uuid "power-12v-00000036-0000-4000-8000-000000000104")
	)

		(title "56_LIGHT_CONNECTORS - logical LED output and harness boundary")
		(date "2026-07-15")
		(rev "B0")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A/B: six LED output/return groups and protected test boundaries")
		(comment 2 "No connector family, pin count, cable, wire gauge, testpoint or footprint selected")
	)
	(lib_symbols)
	(text "56_LIGHT_CONNECTORS - PURPOSE\nGroups six independent regulated LED outputs and their returns for later harness/connector design.\nEach LED channel remains individually identifiable; this sheet does not assign pins or combine outputs.\nLED load current remains outside PCB-B."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.18 1.18)) (justify left))
		(uuid "light-power-00000056-0000-4000-8000-000000000101")
	)
	(text "OUTPUT / RETURN POLICY\nLED_OUTPUTS_1_3 and LED_OUTPUTS_4_6 form the logical group LED_OUTPUTS_1_6 only.\nOutput polarity, return topology, conductor sizing, insulation and allowable voltage drop require final LED and harness data.\nNo shared-output or shared-return scheme is approved here."
		(exclude_from_sim no)
		(at 12 78 0)
		(effects (font (size 1.08 1.08)) (justify left))
		(uuid "light-power-00000056-0000-4000-8000-000000000102")
	)
	(text "CONNECTOR / TEST REQUIREMENTS TBD\nBefore selection, define LED voltage/current tolerances, cable length, environmental sealing, vibration, mating cycles, polarity keying and wrong-mate prevention.\nPower testpoints require guarding and short-circuit control; diagnostic testpoints cannot bypass channel protection."
		(exclude_from_sim no)
		(at 12 144 0)
		(effects (font (size 1.08 1.08)) (justify left))
		(uuid "light-power-00000056-0000-4000-8000-000000000103")
	)

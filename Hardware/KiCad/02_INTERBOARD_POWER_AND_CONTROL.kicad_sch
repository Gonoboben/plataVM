	(lib_symbols)
	(text "02_INTERBOARD_POWER_AND_CONTROL - LOGICAL MATRIX LEVEL A\nPurpose: split interboard links into power, control, diagnostics and safety groups.\nThis sheet defines logical grouping only; physical connector choice is TBD."
		(exclude_from_sim no)
		(at 12 10 0)
		(effects
			(font
				(size 1.65 1.65)
			)
			(justify left)
		)
		(uuid "8b2d04e2-1a66-4d2e-9d32-000000000201")
	)
	(text "POWER DISTRIBUTION FROM PCB-A_BFE_POWER\nPACK_BUS_CRIT_IN  -> PCB-B_CTRL_RESERVE\nPACK_BUS_P12_IN   -> PCB-C_POWER_12V\nPACK_BUS_P5_IN    -> PCB-D_POWER_5V\nPACK_BUS_LIGHT_IN -> PCB-E_LIGHT_POWER\nReturn: POWER_GND unless a local isolated/signal domain is explicitly defined."
		(exclude_from_sim no)
		(at 12 38 0)
		(effects
			(font
				(size 1.35 1.35)
			)
			(justify left)
		)
		(uuid "8b2d04e2-1a66-4d2e-9d32-000000000202")
	)
	(text "PCB-B -> PCB-A CONTROL\nBAT1/2_MAIN_SW_EN\nBAT1/2_BALANCE_SW_EN\nBAT1/2_HOLD_LOOP_OPEN_CMD\nPACK_BUS_DISCHARGE_EN\nEXT_KILL_HW_CHAIN"
		(exclude_from_sim no)
		(at 115 38 0)
		(effects
			(font
				(size 1.35 1.35)
			)
			(justify left)
		)
		(uuid "8b2d04e2-1a66-4d2e-9d32-000000000203")
	)
	(text "PCB-A -> PCB-B DIAGNOSTICS\nBAT1/2_PRESENT\nBAT1/2_VSENSE\nBAT1/2_ISENSE\nPACK_BUS_VSENSE\nBFE_FAULTS, temperatures, OPEN/CLOSED status TBD"
		(exclude_from_sim no)
		(at 210 38 0)
		(effects
			(font
				(size 1.35 1.35)
			)
			(justify left)
		)
		(uuid "8b2d04e2-1a66-4d2e-9d32-000000000204")
	)
	(text "PCB-B -> PCB-C POWER_12V CONTROL\nP12_CH_EN[1..11]\nP12_DIAG_MUX / SPI / I2C TBD\nP12_BOARD_ENABLE\nP12_FAULT_RESET TBD"
		(exclude_from_sim no)
		(at 12 108 0)
		(effects
			(font
				(size 1.35 1.35)
			)
			(justify left)
		)
		(uuid "8b2d04e2-1a66-4d2e-9d32-000000000205")
	)
	(text "PCB-C -> PCB-B DIAGNOSTICS\nCH current/fault/status\nAlways-On CH12..CH14 monitoring\nBoard temperature\nInterface method TBD: parallel, muxed analog, SPI/I2C/other."
		(exclude_from_sim no)
		(at 115 108 0)
		(effects
			(font
				(size 1.35 1.35)
			)
			(justify left)
		)
		(uuid "8b2d04e2-1a66-4d2e-9d32-000000000206")
	)
	(text "PCB-B -> PCB-D POWER_5V CONTROL\n5V_SYS_EN\nP5_OUT_EN[1..7]\nP5_FAULT_RESET TBD\nDC/DC status interface TBD"
		(exclude_from_sim no)
		(at 12 160 0)
		(effects
			(font
				(size 1.35 1.35)
			)
			(justify left)
		)
		(uuid "8b2d04e2-1a66-4d2e-9d32-000000000207")
	)
	(text "PCB-D -> PCB-B DIAGNOSTICS\n5V_SYS_VSENSE / ISENSE\n5V_OUT current/fault/status\nAlways-On outputs monitoring\nBoard temperature"
		(exclude_from_sim no)
		(at 115 160 0)
		(effects
			(font
				(size 1.35 1.35)
			)
			(justify left)
		)
		(uuid "8b2d04e2-1a66-4d2e-9d32-000000000208")
	)
	(text "PCB-B <-> PCB-E LIGHT_POWER\nControls: LIGHT_BRANCH_EN, LED_PWM[1..6], driver enable/reset TBD.\nDiagnostics: LED current, open/short, driver fault, board temperature."
		(exclude_from_sim no)
		(at 210 108 0)
		(effects
			(font
				(size 1.35 1.35)
			)
			(justify left)
		)
		(uuid "8b2d04e2-1a66-4d2e-9d32-000000000209")
	)
	(text "SAFETY AND GROUND POLICY\nEXT_KILL_HW must reach PCB-A final actuators without relying on MCU firmware.\nPOWER_GND, SIGNAL_GND, ISO_GND and CHASSIS are not automatically shorted here.\nShield/chassis termination and reference-ground policy remain a dedicated decision."
		(exclude_from_sim no)
		(at 12 216 0)
		(effects
			(font
				(size 1.25 1.25)
			)
			(justify left)
		)
		(uuid "8b2d04e2-1a66-4d2e-9d32-000000000210")
	)
	(text "PRELIMINARY PIN-COUNT ESTIMATE\nA<->B logic/diagnostics: approx. 20..32 low-speed pins + power/returns.\nB<->C: approx. 16..32 pins unless diagnostics are serialized/muxed.\nB<->D: approx. 12..24 pins. B<->E: approx. 12..24 pins.\nFinal pin-count waits for MCU, diagnostics topology and connector mechanics."
		(exclude_from_sim no)
		(at 170 216 0)
		(effects
			(font
				(size 1.25 1.25)
			)
			(justify left)
		)
		(uuid "8b2d04e2-1a66-4d2e-9d32-000000000211")
	)

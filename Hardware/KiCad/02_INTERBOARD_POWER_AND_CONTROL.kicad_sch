		(title "02_INTERBOARD_POWER_AND_CONTROL")
		(date "2026-07-16")
		(rev "A2")
		(company "Gonoboben/plataVM")
		(comment 1 "V1.6 transport baseline: CAN-FD normal traffic plus direct hardware safety/fault lines")
		(comment 2 "No connector family or final physical pinout selected")
	)
	(lib_symbols)
	(text "02_INTERBOARD_POWER_AND_CONTROL - V1.6 LOGICAL MATRIX\nPower branches remain separate. PCB-A/PCB-B critical paths remain direct.\nPCB-B communicates with PCB-C/D/E by internal CAN-FD for normal commands and telemetry.\nSAFE/HARD_OFF, EXT_KILL and board-fault summaries remain direct hardware lines."
		(exclude_from_sim no)
		(at 12 10 0)
		(effects (font (size 1.45 1.45)) (justify left))
		(uuid "ib-v16-02-101")
	)
	(text "POWER DISTRIBUTION FROM PCB-A\nPACK_BUS_CRIT_IN -> PCB-B\nPACK_BUS_P12_IN -> PCB-C\nPACK_BUS_P5_IN -> PCB-D\nPACK_BUS_LIGHT_IN -> PCB-E\nReturns use POWER_GND; high current never passes through PCB-B or the signal backplane."
		(exclude_from_sim no)
		(at 12 52 0)
		(effects (font (size 1.18 1.18)) (justify left))
		(uuid "ib-v16-02-102")
	)
	(text "PCB-A <-> PCB-B DIRECT CRITICAL CONTRACT\nControls: BAT1/2_MAIN_SW_EN, BAT1/2_BALANCE_SW_EN, BAT1/2_HOLD_LOOP_OPEN_CMD, PACK_BUS_DISCHARGE_EN, EXT_KILL_HW_CHAIN.\nDiagnostics: BAT1/2_PRESENT, BAT1/2_VSENSE, BAT1/2_ISENSE, PACK_BUS_VSENSE and canonical BFE/BALANCE faults."
		(exclude_from_sim no)
		(at 150 52 0)
		(effects (font (size 1.12 1.12)) (justify left))
		(uuid "ib-v16-02-103")
	)
	(text "PCB-B <-> PCB-C/D/E NORMAL TRANSPORT\nCAN_INT_H / CAN_INT_L carry normal commands, setpoints, detailed per-channel telemetry and service data.\nCAN-FD loss cannot block local protection or hardware OFF. Physical topology is linear with termination at two ends; node order follows 3D layout."
		(exclude_from_sim no)
		(at 12 125 0)
		(effects (font (size 1.14 1.14)) (justify left))
		(uuid "ib-v16-02-104")
	)
	(text "DIRECT HARDWARE LINES\nPCB-C: P12_GROUP_SAFE_OFF, P12_GROUP_HARD_OFF, P12_BOARD_FAULT_N.\nPCB-D: P5_GROUP_SAFE_OFF, P5_GROUP_HARD_OFF, P5_BOARD_FAULT_N.\nPCB-E: LIGHT_GROUP_HARD_OFF, LIGHT_BOARD_FAULT_N.\nEXT_KILL_HW_CHAIN remains independent of MCU, CAN-FD and external RS-485."
		(exclude_from_sim no)
		(at 12 186 0)
		(effects (font (size 1.12 1.12)) (justify left))
		(uuid "ib-v16-02-105")
	)
	(text "GROUND / SHIELD POLICY\nSIGNAL_GND and POWER_GND meet at one controlled PCB-B net-tie/configurable point only.\nISO_GND remains DC-isolated. Cable shields terminate to CHASSIS at entry.\nOptional ISO_GND-to-CHASSIS HF coupling is deferred to EMC review."
		(exclude_from_sim no)
		(at 190 186 0)
		(effects (font (size 1.12 1.12)) (justify left))
		(uuid "ib-v16-02-106")
	)
	(text "PIN-COUNT BASIS\nC/D/E normal traffic uses one CAN-FD differential pair plus reference/shield provisions.\nDirect pins are limited to power, SAFE/HARD_OFF, board-fault summary and required returns.\nFinal connector pin count awaits 3D placement, termination location and service reserve of 20-30 percent."
		(exclude_from_sim no)
		(at 12 246 0)
		(effects (font (size 1.08 1.08)) (justify left))
		(uuid "ib-v16-02-107")
	)

    (date "2026-07-14")
    (rev "A0")
    (comment 1 "Logical interboard interface matrix placeholder")
  )
  (text "POWER DISTRIBUTION FROM PCB-A:\nPACK_BUS_CRIT_IN -> PCB-B_CTRL_RESERVE\nPACK_BUS_P12_IN -> PCB-C_POWER_12V\nPACK_BUS_P5_IN -> PCB-D_POWER_5V\nPACK_BUS_LIGHT_IN -> PCB-E_LIGHT_POWER\nAll returns use POWER_GND unless a local isolated/signal domain is explicitly defined."
    (at 20 25 0)
    (effects (font (size 1.8 1.8)) (justify left))
  )
  (text "CONTROL FROM PCB-B:\nBATx_MAIN_SW_EN, BATx_BALANCE_SW_EN, BATx_HOLD_LOOP_OPEN_CMD, PACK_BUS_DISCHARGE_EN, EXT_KILL_HW.\nP12_CH_EN[1..11], P5_OUT_EN[1..7], 5V_SYS_EN, LIGHT_BRANCH_EN, LED_PWM[1..6]."
    (at 20 85 0)
    (effects (font (size 1.8 1.8)) (justify left))
  )
  (text "DIAGNOSTICS TO PCB-B:\nBATx_PRESENT, BATx_VSENSE, BATx_ISENSE, PACK_BUS_VSENSE, board faults, channel faults, current sense, temperatures.\nPhysical connector choice and pin count are TBD."
    (at 20 135 0)
    (effects (font (size 1.8 1.8)) (justify left))
  )

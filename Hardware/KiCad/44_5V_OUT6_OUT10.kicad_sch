	(title_block
		(title "44_5V_OUT6_OUT10 - controlled and Always-On output group")
		(date "2026-07-15")
		(rev "B0")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A/B: OUT6..OUT7 controlled, OUT8..OUT10 Always-On monitored")
		(comment 2 "No load switch, protection, sensor, connector or footprint selected")
	)
	(lib_symbols)
	(text "44_5V_OUT6_OUT10 - PURPOSE\nDefines five independent output instances based on sheet 42.\nOUT6..OUT7 have independent normal enables. OUT8..OUT10 are Always-On monitored in normal RUN.\nAll five remain protected and subject to group SAFE/HARD_OFF."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.18 1.18)) (justify left))
		(uuid "power-5v-00000044-0000-4000-8000-000000000101")
	)
	(text "CONTROLLED / ALWAYS-ON POLICY\nP5_OUT_EN_6_7 carries two normal-control enables.\nP5_AON_POLICY_OUT8_10 is a local placeholder for the approved always-enabled implementation.\nAlways-On does not override P5_GROUP_SAFE_OFF, P5_GROUP_HARD_OFF or individual protection."
		(exclude_from_sim no)
		(at 12 78 0)
		(effects (font (size 1.10 1.10)) (justify left))
		(uuid "power-5v-00000044-0000-4000-8000-000000000102")
	)
	(text "POWER / DIAGNOSTICS\nThe group preserves output identity as 5V_OUTPUTS_6_10 and diagnostics as P5_OUT_FAULT_N_6_10 / P5_OUT_ISENSE_6_10.\nLoad profiles, inrush, backfeed and simultaneous-load thermal limits remain TBD."
		(exclude_from_sim no)
		(at 12 144 0)
		(effects (font (size 1.12 1.12)) (justify left))
		(uuid "power-5v-00000044-0000-4000-8000-000000000103")
	)

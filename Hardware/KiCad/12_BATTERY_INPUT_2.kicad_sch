	(title_block
		(title "12_BATTERY_INPUT_2 - BFE input from AKB_2")
		(date "2026-07-15")
		(rev "B1")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level B: BAT2 connector boundary and net naming")
		(comment 2 "Symmetric to 11_BATTERY_INPUT_1")
	)
	(lib_symbols)
	(text "12_BATTERY_INPUT_2 - LEVEL B BOUNDARY\nAKB_2 arrives from the external battery housing through SN-176A-12 after BMS, fuse and K_BAT2.\nPins 1..5 are BAT2_SN176_POS. Pins 6..10 are BAT2_SN176_NEG / power return.\nPin 11 is BAT2_HOLD_RETURN_IN. Pin 12 remains reserve.\nLOCAL_START2 is separate and never passes through SN-176A-12."
		(exclude_from_sim no)
		(at 12 16 0)
		(effects (font (size 1.35 1.35)) (justify left))
		(uuid "bfe-dh-00000012-0000-4000-8000-000000000101")
	)
	(text "POWER PATH TO PCB-A\nBAT2_SN176_POS and BAT2_SN176_NEG feed BFE_2 only.\nDo not common BAT1 and BAT2 before their intended combine point in PACK_BUS logic.\nThe upstream K_BAT2 is monostable and external to PCB-A. No K_BAT2 coil energy is generated on PCB-A."
		(exclude_from_sim no)
		(at 12 70 0)
		(effects (font (size 1.25 1.25)) (justify left))
		(uuid "bfe-dh-00000012-0000-4000-8000-000000000102")
	)
	(text "MEASUREMENT / DIAGNOSTIC TAPS\nBAT2 voltage and current measurement access is routed to 18_BATTERY_MEASUREMENTS.\nDo not assume whether BMS is high-side or low-side internally; use only the external protected pair.\nBAT2_PRESENT / OPEN-CLOSED / current status remain diagnostic functions, not BMS telemetry."
		(exclude_from_sim no)
		(at 12 118 0)
		(effects (font (size 1.25 1.25)) (justify left))
		(uuid "bfe-dh-00000012-0000-4000-8000-000000000103")
	)
	(text "HOLD-LOOP BOUNDARY\nBAT2_HOLD_RETURN_IN from pin 11 is routed to 17_REMOTE_OFF_AND_EXT_KILL.\nIf this loop is open, K_BAT2 must release or remain OPEN.\nBMS recovery must not restart K_BAT2 without LOCAL_START2."
		(exclude_from_sim no)
		(at 12 166 0)
		(effects (font (size 1.25 1.25)) (justify left))
		(uuid "bfe-dh-00000012-0000-4000-8000-000000000104")
	)
	(hierarchical_label "BAT2_SN176_POS" (shape passive) (exclude_from_sim no) (at 132 50 0) (effects (font (size 1.1 1.1)) (justify left)) (uuid "bfe-dh-00000012-0000-4000-8000-000000000201"))
	(hierarchical_label "BAT2_SN176_NEG" (shape passive) (exclude_from_sim no) (at 132 58 0) (effects (font (size 1.1 1.1)) (justify left)) (uuid "bfe-dh-00000012-0000-4000-8000-000000000202"))
	(hierarchical_label "BAT2_HOLD_RETURN_IN" (shape passive) (exclude_from_sim no) (at 132 66 0) (effects (font (size 1.1 1.1)) (justify left)) (uuid "bfe-dh-00000012-0000-4000-8000-000000000203"))
	(hierarchical_label "BAT2_TO_MAIN_PATH" (shape passive) (exclude_from_sim no) (at 132 94 0) (effects (font (size 1.1 1.1)) (justify left)) (uuid "bfe-dh-00000012-0000-4000-8000-000000000204"))
	(hierarchical_label "BAT2_MEAS_TAPS" (shape passive) (exclude_from_sim no) (at 132 142 0) (effects (font (size 1.1 1.1)) (justify left)) (uuid "bfe-dh-00000012-0000-4000-8000-000000000205"))

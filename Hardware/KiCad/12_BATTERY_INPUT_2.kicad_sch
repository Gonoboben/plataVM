		(company "Gonoboben/plataVM")
		(comment 1 "Symbol skeleton: BAT2 SN-176A-12 boundary and future connector placement zones")
		(comment 2 "Symmetric to 11_BATTERY_INPUT_1; no connector family or footprint selected")
	)
	(lib_symbols)
	(text "12_BATTERY_INPUT_2 - SYMBOL SKELETON PURPOSE\nThis sheet prepares future KiCad symbol placement for the BAT2 external connector boundary.\nJ_BAT2_SN176_TBD is a future 12-pin connector placeholder for the mating side of SN-176A-12.\nNo physical connector family, footprint, pin hardware, cable section or manufacturer part number is selected here."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.28 1.28)) (justify left))
		(uuid "bfe-symbol-00000012-0000-4000-8000-000000000101")
	)
	(text "J_BAT2_SN176_TBD PIN GROUPING\nPins 1..5  -> BAT2_SN176_POS.\nPins 6..10 -> BAT2_SN176_NEG / protected return.\nPin 11     -> BAT2_HOLD_RETURN_IN.\nPin 12     -> BAT2_SN176_RESERVE, unassigned until explicitly approved.\nLOCAL_START2 remains a separate two-pin momentary NO connector inside the external battery housing. It is not routed through PCB-A."
		(exclude_from_sim no)
		(at 12 62 0)
		(effects (font (size 1.20 1.20)) (justify left))
		(uuid "bfe-symbol-00000012-0000-4000-8000-000000000102")
	)
	(text "POWER / MEASUREMENT BOUNDARY\nBAT2_SN176_POS and BAT2_SN176_NEG feed BFE_2 only and then continue as BAT2_TO_MAIN_PATH.\nBAT2_MEAS_TAPS are provided for voltage/current/status measurement on 18_BATTERY_MEASUREMENTS.\nDo not assume BMS internal high-side or low-side topology; use only the external protected pair."
		(exclude_from_sim no)
		(at 12 128 0)
		(effects (font (size 1.20 1.20)) (justify left))
		(uuid "bfe-symbol-00000012-0000-4000-8000-000000000103")
	)
	(text "HOLD-LOOP / SAFE STATE\nBAT2_HOLD_RETURN_IN from pin 11 is routed to 17_REMOTE_OFF_AND_EXT_KILL.\nIf this loop is open, K_BAT2 must release or remain OPEN.\nBMS recovery must not restart K_BAT2 without LOCAL_START2.\nFuture real connector symbol shall preserve these net names exactly."
		(exclude_from_sim no)
		(at 12 184 0)
		(effects (font (size 1.18 1.18)) (justify left))
		(uuid "bfe-symbol-00000012-0000-4000-8000-000000000104")
	)
	(hierarchical_label "BAT2_SN176_POS" (shape passive) (exclude_from_sim no) (at 138 44 0) (effects (font (size 1.1 1.1)) (justify left)) (uuid "bfe-symbol-00000012-0000-4000-8000-000000000201"))
	(hierarchical_label "BAT2_SN176_NEG" (shape passive) (exclude_from_sim no) (at 138 52 0) (effects (font (size 1.1 1.1)) (justify left)) (uuid "bfe-symbol-00000012-0000-4000-8000-000000000202"))

		(title "31_POWER_12V_INPUT_PROTECTION - PCB-C branch input boundary")
		(date "2026-07-15")
		(rev "B0")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A/B: PACK_BUS_P12_IN protection, bulk energy and sensing zones")
		(comment 2 "No fuse, eFuse, TVS, reverse protection, capacitor, connector or footprint selected")
	)
	(lib_symbols)
	(text "31_POWER_12V_INPUT_PROTECTION - PURPOSE\nDefines the PCB-C power-entry boundary from PCB-A.\nPACK_BUS_P12_IN and POWER_GND enter directly from the star-distributed power harness.\nThis sheet does not route load current through PCB-B."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.26 1.26)) (justify left))
		(uuid "power-12v-00000031-0000-4000-8000-000000000101")
	)
	(text "INPUT PROTECTION ZONE\nFuture protection must address branch overcurrent, reverse connection/current, transients and credible harness faults.\nProtection coordination with PCB-A and per-channel protection remains TBD.\nThe safe result of a branch fault is loss of PCB-C outputs without defeating other system branches."
		(exclude_from_sim no)
		(at 12 72 0)
		(effects (font (size 1.14 1.14)) (justify left))
		(uuid "power-12v-00000031-0000-4000-8000-000000000102")
	)
	(text "BULK ENERGY / INRUSH ZONE\nLocal bulk capacitance may support channel transients, but charging inrush must not disturb PACK_BUS or unintentionally trip upstream protection.\nCapacitance, damping, precharge/inrush topology and discharge time remain TBD."
		(exclude_from_sim no)
		(at 12 134 0)
		(effects (font (size 1.14 1.14)) (justify left))
		(uuid "power-12v-00000031-0000-4000-8000-000000000103")
	)
	(text "INPUT DIAGNOSTICS\nP12_INPUT_VSENSE is the canonical board input-voltage diagnostic.\nP12_INPUT_FAULT_N and P12_INPUT_PRESENT are local conditioned placeholders for later board-fault aggregation.\nRanges, filtering, reference method and transport remain TBD."
		(exclude_from_sim no)
		(at 12 194 0)
		(effects (font (size 1.14 1.14)) (justify left))
		(uuid "power-12v-00000031-0000-4000-8000-000000000104")
	)

	)
	(text "K_BATx HOLD LOOP:\nBAT_PROT+ -> F_CTRL -> LOCAL_START_NO || K_BAT_AUX_NO -> K_BAT_COIL -> pin 11 -> REMOTE_OFF_NC / EXT_KILL_NC -> BAT_PROT-."

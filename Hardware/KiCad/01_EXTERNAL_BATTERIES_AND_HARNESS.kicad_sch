		)
		(uuid "4fa09f48-7962-44ab-9df6-00b0bfdd2321")
	)
	(text "BATTERY HOUSING BOUNDARY:\nАКБ_1 / АКБ_2: LiFePO4 4S24P -> autonomous BMS -> BAT_PROT+ / BAT_PROT- -> power fuse -> monostable K_BATx -> СН-176А-12.\nNo MCU, no RS-485/CAN/UART, no digital BMS telemetry, no raw branch."
		(exclude_from_sim no)
		(at 20 25 0)
		(effects
			(font
				(size 1.8 1.8)
			)
			(justify left)
		)

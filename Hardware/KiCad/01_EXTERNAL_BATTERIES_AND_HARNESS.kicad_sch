		(title "01_EXTERNAL_BATTERIES_AND_HARNESS")
		(date "2026-07-15")
		(rev "A1")
		(company "Gonoboben/plataVM")
		(comment 1 "External battery housings, SN-176A-12, LOCAL_START and K_BATx hold-loop")
		(comment 2 "No contactor model, fuse rating, suppressor or connector family selected here")
	)
	(lib_symbols)
	(text "01_EXTERNAL_BATTERIES_AND_HARNESS - ARCHITECTURE LEVEL A\nPurpose: define external battery housing boundary, harness naming, SN-176A-12 pinout,\nseparate LOCAL_START connector and K_BATx self-hold loop.\nThis sheet is functional; part numbers and footprints remain TBD."
		(exclude_from_sim no)
		(at 12 10 0)
		(effects
			(font
				(size 1.6 1.6)
			)
			(justify left)
		)
		(uuid "6c8f0d7a-0101-4f2a-9b00-000000010101")
	)
	(text "BATTERY HOUSING COMMON RULES\nАКБ_1 / АКБ_2: LiFePO4 4S24P -> autonomous BMS -> BAT_PROT+ / BAT_PROT-.\nInside housing: BMS, power fuse, monostable K_BATx, K_BAT_AUX_NO, F_CTRL, coil suppression.\nForbidden inside battery housing: MCU, RS-485/CAN/UART, digital BMS telemetry, raw branch."
		(exclude_from_sim no)
		(at 12 34 0)
		(effects
			(font
				(size 1.35 1.35)
			)
			(justify left)
		)
		(uuid "6c8f0d7a-0101-4f2a-9b00-000000010102")
	)
	(text "BATTERY 1 FUNCTIONAL CHAIN\nBAT1_PROT+ -> F_BAT1 -> K_BAT1_MAIN_NO -> SN176_BAT1_PINS_1_5 -> PCB-A/BFE_1.\nBAT1_PROT- -> SN176_BAT1_PINS_6_10 -> PCB-A/BFE_1.\nPin 11: BAT1_HOLD_RETURN / REMOTE_OFF1_LOOP. Pin 12: reserve."
		(exclude_from_sim no)
		(at 12 82 0)
		(effects
			(font
				(size 1.35 1.35)
			)
			(justify left)
		)
		(uuid "6c8f0d7a-0101-4f2a-9b00-000000010103")
	)
	(text "BATTERY 2 FUNCTIONAL CHAIN\nBAT2_PROT+ -> F_BAT2 -> K_BAT2_MAIN_NO -> SN176_BAT2_PINS_1_5 -> PCB-A/BFE_2.\nBAT2_PROT- -> SN176_BAT2_PINS_6_10 -> PCB-A/BFE_2.\nPin 11: BAT2_HOLD_RETURN / REMOTE_OFF2_LOOP. Pin 12: reserve."
		(exclude_from_sim no)
		(at 150 82 0)
		(effects
			(font
				(size 1.35 1.35)
			)
			(justify left)
		)
		(uuid "6c8f0d7a-0101-4f2a-9b00-000000010104")
	)
	(text "LOCAL_START CONNECTOR - SEPARATE 2-PIN, MOMENTARY NO\nLSx_A: node after F_CTRLx. LSx_B: coil positive / self-hold node.\nLOCAL_START must not pass through SN-176A-12 and must not latch mechanically.\nREMOTE_OFF / EXT_KILL have priority over LOCAL_START."
		(exclude_from_sim no)
		(at 12 138 0)
		(effects
			(font
				(size 1.35 1.35)
			)
			(justify left)
		)
		(uuid "6c8f0d7a-0101-4f2a-9b00-000000010105")
	)
	(text "K_BATx HOLD LOOP FUNCTION\nBATx_PROT+ -> F_CTRLx -> (LOCAL_START_NO || K_BATx_AUX_NO) -> K_BATx_COIL ->\nSN-176A-12 pin 11 -> REMOTE_OFFx_NC / EXT_KILL_NC on PCB-A -> BATx_PROT-.\nBMS output loss opens K_BATx; BMS recovery must not auto-restart K_BATx."
		(exclude_from_sim no)
		(at 150 138 0)
		(effects
			(font
				(size 1.35 1.35)
			)
			(justify left)
		)
		(uuid "6c8f0d7a-0101-4f2a-9b00-000000010106")
	)
	(text "HARNESS / NAMING BOUNDARY\nBATx_PROT+/BATx_PROT- are inside protected BMS output domain.\nBATx+/BATx- at SN-176A-12 are external power pins after K_BATx main contact.\nREMOTE_OFFx_LOOP is a hold-loop return path, not digital telemetry and not a RESET coil pulse."
		(exclude_from_sim no)
		(at 12 204 0)
		(effects
			(font
				(size 1.25 1.25)
			)
			(justify left)
		)
		(uuid "6c8f0d7a-0101-4f2a-9b00-000000010107")
	)

	(lib_symbols)
	(text "SN-176A-12 PINOUT:\nPins 1-5: BAT+\nPins 6-10: BAT-\nPin 11: REMOTE_OFF / K_BAT_HOLD_RETURN\nPin 12: RESERVE\nLOCAL_START is separate 2-pin momentary NO connector and does not pass through SN-176A-12."
		(exclude_from_sim no)

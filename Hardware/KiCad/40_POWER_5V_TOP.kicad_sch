		(title "40_POWER_5V_TOP - PCB-D_POWER_5V")
		(date "2026-07-15")
		(rev "A2")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A/B: 5V_SYS conversion and ten-output detailed hierarchy")
		(comment 2 "Sub-sheets 41..46 define functional boundaries only; no components selected")
	)
	(lib_symbols)
	(text "40_POWER_5V_TOP - DETAILED HIERARCHY MAP\nPCB-D converts PACK_BUS_P5_IN to 5V_SYS_BUS and distributes ten protected 5 V outputs.\nOUT1..OUT7 are normally controlled; OUT8..OUT10 are Always-On monitored.\n5V_SYS does not power PCB-B critical rails and is not supplied by EMG."
		(exclude_from_sim no)
		(at 12 12 0)
		(effects (font (size 1.34 1.34)) (justify left))
		(uuid "p5-top-00000040-0000-4000-8000-000000000101")
	)
	(text "SUB-SHEETS 41..43\n41_5V_DC_DC: PACK_BUS input boundary, conversion, 5V_SYS control and primary diagnostics\n42_5V_OUTPUT_TEMPLATE: reusable output protection/control/diagnostic contract\n43_5V_OUT1_OUT5: five normally controlled output instances"
		(exclude_from_sim no)
		(at 12 72 0)
		(effects (font (size 1.16 1.16)) (justify left))
		(uuid "p5-top-00000040-0000-4000-8000-000000000102")
	)
	(text "SUB-SHEETS 44..46\n44_5V_OUT6_OUT10: OUT6..OUT7 controlled plus OUT8..OUT10 Always-On monitored\n45_5V_DIAGNOSTICS: output and 5V_SYS diagnostic aggregation toward PCB-B\n46_5V_CONNECTORS: logical output/return, harness and test boundaries"
		(exclude_from_sim no)
		(at 168 72 0)
		(effects (font (size 1.16 1.16)) (justify left))
		(uuid "p5-top-00000040-0000-4000-8000-000000000103")
	)
	(text "POWER / THERMAL CONSTRAINTS\nPreliminary board budget: 15 A continuous and 20 A short peak on 5V_SYS_BUS.\nA single output may require up to 3 A only within the total converter, copper and thermal budget.\nEfficiency, switching frequency, magnetics, inrush, ripple, transient response and cooling remain TBD."
		(exclude_from_sim no)
		(at 12 150 0)
		(effects (font (size 1.10 1.10)) (justify left))
		(uuid "p5-top-00000040-0000-4000-8000-000000000104")
	)
	(text "SAFE / ARCHITECTURE RULES\n5V_SYS_EN controls the conversion path; P5_GROUP_SAFE_OFF and P5_GROUP_HARD_OFF override output enables.\nAlways-On outputs remain protected and subject to SAFE/HARD_OFF.\nNo DC/DC, eFuse, load switch, connector, footprint, BOM or layout is selected."
		(exclude_from_sim no)
		(at 12 214 0)
		(effects (font (size 1.10 1.10)) (justify left))
		(uuid "p5-top-00000040-0000-4000-8000-000000000105")
	)

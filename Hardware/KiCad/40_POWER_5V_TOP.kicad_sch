  (title_block
    (title "40_POWER_5V_TOP - PCB-D_POWER_5V")
    (date "2026-07-14")
    (rev "A0")
    (comment 1 "5V_SYS DC/DC and ten protected 5V outputs")
  )
  (text "PCB-D_POWER_5V CONTAINS:\nPACK_BUS_P5_IN input, 5V_SYS DC/DC, 5V_OUT1..5V_OUT10, output protection, current diagnostics, thermal diagnostics and output connectors.\nPreliminary total limit: 15 A continuous / 20 A peak."
    (at 20 25 0)
    (effects (font (size 1.8 1.8)) (justify left))
  )
  (text "CONTROL INPUTS:\n5V_SYS_EN, P5_OUT_EN[1..7], P5_GROUP_SAFE_OFF, P5_GROUP_HARD_OFF.\n5V_OUT8..5V_OUT10 are Always-On monitored, but must be disabled by protection, SAFE and HARD_OFF."
    (at 20 75 0)
    (effects (font (size 1.8 1.8)) (justify left))
  )
  (text "DIAGNOSTICS OUTPUTS:\nP5_OUT_FAULT_N[1..10], P5_OUT_ISENSE[1..10], 5V_SYS_VSENSE, 5V_SYS_TOTAL_ISENSE, P5_BOARD_TEMP, P5_BOARD_FAULT_N.\n5V_SYS_BUS does not power MCU critical domain."
    (at 20 125 0)
    (effects (font (size 1.8 1.8)) (justify left))
  )
  (sheet_instances
    (path "/40_POWER_5V_TOP" (page "8"))
  )
)

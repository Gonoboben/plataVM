	(title_block
		(title "40_POWER_5V_TOP - PCB-D_POWER_5V")
		(date "2026-07-15")
		(rev "A1")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A: 5V_SYS DC/DC and ten 5V outputs")
		(comment 2 "No DC/DC/eFuse part numbers or footprints selected")
	)
	(lib_symbols)
	(text "40_POWER_5V_TOP - PCB-D_POWER_5V\nPurpose: define 5V_SYS conversion, ten protected outputs and diagnostics boundaries.\nPreliminary total budget: 15 A continuous / 20 A peak; final thermal design TBD."
		(exclude_from_sim no)
		(at 12 10 0)
		(effects (font (size 1.55 1.55)) (justify left))
		(uuid "p5-text-0001")
	)
	(text "POWER INPUT / DC-DC\nPACK_BUS_P5_IN feeds 5V_SYS DC/DC.\nInput protection, precharge/inrush, filtering and thermal path are TBD.\n5V_SYS converter is not selected on this sheet."
		(exclude_from_sim no)
		(at 12 38 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "p5-text-0002")
	)
	(text "CONTROLLED OUTPUTS\n5V_OUT1..5V_OUT7 are MCU-controlled through PCB-B.\nEach output requires enable, current diagnostics and fault status.\nPer-output max preliminary 3 A, final derating TBD."
		(exclude_from_sim no)
		(at 112 38 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "p5-text-0003")
	)
	(text "ALWAYS-ON MONITORED OUTPUTS\n5V_OUT8..5V_OUT10 are Always-On monitored.\nThey remain protected and diagnostic; HARD_OFF/SAFE behavior must be defined.\nThey do not imply uncontrolled permanent power."
		(exclude_from_sim no)
		(at 222 38 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "p5-text-0004")
	)
	(text "OUTPUT PROTECTION\nPer-output eFuse/high-side/load-switch topology TBD.\nShort-circuit, inrush and backfeed behavior must be checked.\nConnector and wire gauge are not frozen."
		(exclude_from_sim no)
		(at 12 112 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "p5-text-0005")
	)
	(text "DIAGNOSTICS TO PCB-B\n5V_SYS voltage/current, per-output current/fault/status, Always-On monitoring, board temperature.\nParallel vs serialized/muxed diagnostics remain TBD.\nADC range and filtering depend on MCU choice."
		(exclude_from_sim no)
		(at 112 112 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "p5-text-0006")
	)
	(text "THERMAL / EMC\nDC/DC and output switches likely dominate heat on PCB-D.\nSwitching node, filter, ground and shield policy must be solved before PCB layout.\nNo automatic POWER_GND/SIGNAL_GND/CHASSIS short here."
		(exclude_from_sim no)
		(at 222 112 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "p5-text-0007")
	)
	(text "SAFE STATES\nFaulted 5V output must isolate without destabilizing 5V_SYS.\nHARD_OFF/EXT_KILL must bring the board to defined safe state.\nCritical 5V/3V3 are on PCB-B, not this high-current 5V output board."
		(exclude_from_sim no)
		(at 12 190 0)
		(effects (font (size 1.25 1.25)) (justify left))
		(uuid "p5-text-0008")
	)

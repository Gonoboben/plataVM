		(title "46_5V_CONNECTORS - logical output and harness boundary")
		(date "2026-07-15")
		(rev "B0")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A/B: ten output/return groups and service test boundaries")
		(comment 2 "No connector family, pin count, wire gauge, cable, testpoint or footprint selected")
	)
	(lib_symbols)
	(text "46_5V_CONNECTORS - PURPOSE\nGroups ten protected 5 V outputs and their returns for later harness/connector design.\nEach output remains individually identifiable; this sheet does not assign pins or combine channels.\nPCB-D output current does not pass through PCB-B."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.20 1.20)) (justify left))
		(uuid "power-5v-00000046-0000-4000-8000-000000000101")
	)
	(text "OUTPUT / RETURN POLICY\n5V_OUTPUTS_1_5 and 5V_OUTPUTS_6_10 form the logical group 5V_OUTPUTS_1_10 only.\nReturn topology, conductor sizing, allowable voltage drop and shared-return policy require load and harness data.\nNo connector or wire gauge is approved here."
		(exclude_from_sim no)
		(at 12 78 0)
		(effects (font (size 1.10 1.10)) (justify left))
		(uuid "power-5v-00000046-0000-4000-8000-000000000102")
	)
	(text "CONNECTOR / TEST REQUIREMENTS TBD\nDefine per-output load, inrush, duty cycle, cable length, environmental sealing, vibration, mating cycles and wrong-mate prevention before connector selection.\nPower testpoints require guarding and short-circuit protection; low-energy testpoints must not bypass output protection."
		(exclude_from_sim no)
		(at 12 144 0)
		(effects (font (size 1.10 1.10)) (justify left))
		(uuid "power-5v-00000046-0000-4000-8000-000000000103")
	)

	(title_block
		(title "35_POWER_12V_DIAGNOSTICS - channel and board diagnostics")
		(date "2026-07-15")
		(rev "B0")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A/B: 14-channel fault/current and board-state aggregation")
		(comment 2 "No ADC, mux, local controller, sensor, serializer, isolator or footprint selected")
	)
	(lib_symbols)
	(text "35_POWER_12V_DIAGNOSTICS - PURPOSE\nAggregates PCB-C channel and board diagnostics toward PCB-B while preserving channel identity.\nThe logical interface is fixed; direct parallel, muxed analog or local digital transport remains TBD.\nDiagnostic availability is not required for hardware HARD_OFF action."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.22 1.22)) (justify left))
		(uuid "power-12v-00000035-0000-4000-8000-000000000101")
	)
	(text "CHANNEL DIAGNOSTICS\nP12_CH_FAULT_N_1_7 plus P12_CH_FAULT_N_8_14 form canonical P12_CH_FAULT_N_1_14.\nP12_CH_ISENSE_1_7 plus P12_CH_ISENSE_8_14 form canonical P12_CH_ISENSE_1_14.\nFault polarity, current range, accuracy, bandwidth and calibration remain TBD."
		(exclude_from_sim no)
		(at 12 76 0)
		(effects (font (size 1.12 1.12)) (justify left))
		(uuid "power-12v-00000035-0000-4000-8000-000000000102")
	)
	(text "BOARD DIAGNOSTICS\nP12_INPUT_VSENSE and P12_BOARD_TEMP are canonical board-level observations.\nP12_BOARD_FAULT_N is a conditioned summary of input, thermal and channel-critical faults, without hiding individual fault bits.\nThresholds, debounce, latching and reset policy remain TBD."
		(exclude_from_sim no)
		(at 12 138 0)
		(effects (font (size 1.12 1.12)) (justify left))
		(uuid "power-12v-00000035-0000-4000-8000-000000000103")
	)
	(text "INTERBOARD BOUNDARY\nDIAG_C_TO_B_P12 is the grouped logical link toward PCB-B.\nAnalog signals require an explicit reference and protection before a physical connector is selected.\nExternal isolated RS-485 is not automatically reused for this internal interface."
		(exclude_from_sim no)
		(at 12 202 0)
		(effects (font (size 1.12 1.12)) (justify left))
		(uuid "power-12v-00000035-0000-4000-8000-000000000104")
	)

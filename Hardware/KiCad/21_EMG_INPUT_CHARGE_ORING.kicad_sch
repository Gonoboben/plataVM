	(paper "A3")
	(title_block
		(title "21_EMG_INPUT_CHARGE_ORING - reserve source and EMG keep-alive boundary")
		(date "2026-07-15")
		(rev "B0")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A/B: PACK_BUS critical input, EMG_4S2P, charge/ORing and KEEP_ALIVE zones")
		(comment 2 "Text-only placeholders; no charger, BMS, ideal-diode, fuse, connector or footprint selected")
	)
	(lib_symbols)
	(text "21_EMG_INPUT_CHARGE_ORING - PURPOSE\nDefines the reserve-energy boundary of PCB-B_CTRL_RESERVE.\nPACK_BUS_CRIT_IN may charge/feed the critical domain; EMG_4S2P sustains only the critical domain after HARD_OFF.\nNo high-current external load may be powered through this sheet."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.28 1.28)) (justify left))
		(uuid "ctrl-reserve-00000021-0000-4000-8000-000000000101")
	)
	(text "PACK_BUS CRITICAL INPUT / RESERVE BRANCH\nPACK_BUS_CRIT_IN enters through a future limited protection and charge-control zone.\nRESERVE_BRANCH is not PACK_BUS distribution and must not carry CH, 5V_SYS or LED load currents.\nInput protection, current limit and reverse-current policy remain TBD."
		(exclude_from_sim no)
		(at 12 66 0)
		(effects (font (size 1.18 1.18)) (justify left))
		(uuid "ctrl-reserve-00000021-0000-4000-8000-000000000102")
	)
	(text "EMG_4S2P / CHARGE / ORING\nFuture charge-control and source-selection blocks shall prevent uncontrolled backfeed between PACK_BUS_CRIT_IN and EMG_4S2P.\nEMG battery chemistry, charge limits, protection implementation and connector family are not selected here.\nLoss or recovery of PACK_BUS must not create an unintended restart of external battery contactors."
		(exclude_from_sim no)
		(at 12 124 0)
		(effects (font (size 1.18 1.18)) (justify left))
		(uuid "ctrl-reserve-00000021-0000-4000-8000-000000000103")
	)
	(text "KEEP_ALIVE FUNCTION\nKEEP_ALIVE_SOURCE sustains MCU logging, fault latching, RS-485 status and controlled shutdown for a bounded interval.\nIt must not override EXT_KILL, HARD_OFF or any final actuator command.\nRequired hold-up time, load shedding order and recharge policy remain TBD and must be calculated later."
		(exclude_from_sim no)
		(at 12 188 0)
		(effects (font (size 1.16 1.16)) (justify left))
		(uuid "ctrl-reserve-00000021-0000-4000-8000-000000000104")
	)

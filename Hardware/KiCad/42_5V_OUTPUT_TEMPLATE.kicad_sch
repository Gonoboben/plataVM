	(title_block
		(title "42_5V_OUTPUT_TEMPLATE - single-output functional contract")
		(date "2026-07-15")
		(rev "B0")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A/B: protected 5 V output control and diagnostics")
		(comment 2 "No load switch, eFuse, sensor, suppression, connector or footprint selected")
	)
	(lib_symbols)
	(text "42_5V_OUTPUT_TEMPLATE - PURPOSE\nDefines the common functional contract for each of ten protected 5 V outputs.\nA single output may require up to 3 A only within the total 15 A continuous / 20 A peak board budget.\nThe template does not instantiate a selected component."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.20 1.20)) (justify left))
		(uuid "power-5v-00000042-0000-4000-8000-000000000101")
	)
	(text "CONTROL / SAFE STATE\nP5_OUT_EN is used for normally controlled outputs; Always-On outputs use a later approved local policy.\nP5_OUT_SAFE_OFF and P5_OUT_HARD_OFF override normal enable.\nReset, brownout and disconnected-control states must resolve to the output-specific safe state."
		(exclude_from_sim no)
		(at 12 78 0)
		(effects (font (size 1.12 1.12)) (justify left))
		(uuid "power-5v-00000042-0000-4000-8000-000000000102")
	)
	(text "PROTECTION / DIAGNOSTICS\nFuture topology must contain overload, short-circuit, inrush and backfeed without destabilizing 5V_SYS_BUS.\nEach output provides P5_OUT_FAULT_N and P5_OUT_ISENSE.\nFault timing, current range, accuracy, output discharge and retry policy remain TBD."
		(exclude_from_sim no)
		(at 12 146 0)
		(effects (font (size 1.12 1.12)) (justify left))
		(uuid "power-5v-00000042-0000-4000-8000-000000000103")
	)

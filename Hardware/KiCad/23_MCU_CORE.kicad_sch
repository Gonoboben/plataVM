	(title_block
		(title "23_MCU_CORE - control processor functional boundary")
		(date "2026-07-15")
		(rev "B0")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A/B: MCU core, logging and logical interface ownership")
		(comment 2 "No MCU family, clock, memory, ADC, isolation, programming connector or footprint selected")
	)
	(lib_symbols)
	(text "23_MCU_CORE - PURPOSE\nDefines the normal-control processor boundary on PCB-B_CTRL_RESERVE.\nThe MCU performs command processing, diagnostics, logging and controlled shutdown.\nIt is not a required element in the final EXT_KILL actuation path."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.28 1.28)) (justify left))
		(uuid "ctrl-reserve-00000023-0000-4000-8000-000000000101")
	)
	(text "MCU CORE FUNCTIONAL ZONE\nFuture symbols will include the selected processor, clocking, reset, decoupling, boot configuration and required memory.\nPin allocation, voltage domains, ADC strategy and communication peripherals remain TBD.\nNo part number or package is selected at this stage."
		(exclude_from_sim no)
		(at 12 70 0)
		(effects (font (size 1.18 1.18)) (justify left))
		(uuid "ctrl-reserve-00000023-0000-4000-8000-000000000102")
	)
	(text "NORMAL CONTROL / DIAGNOSTICS\nMCU_TO_CONTROL_IO and CONTROL_IO_TO_MCU are logical boundaries only; they do not select parallel, muxed, SPI, I2C or other internal transport.\nThe MCU may issue normal OFF commands and safe-state requests.\nAll externally visible commands require defined defaults during reset, brownout and unpowered conditions."
		(exclude_from_sim no)
		(at 12 130 0)
		(effects (font (size 1.16 1.16)) (justify left))
		(uuid "ctrl-reserve-00000023-0000-4000-8000-000000000103")
	)
	(text "SAFETY LIMIT\nEXT_KILL_EVENT_STATUS may be logged by firmware, but firmware cannot block, postpone or clear EXT_KILL_LATCHED.\nWatchdog/supervisor may reset or contain the MCU independently.\nBMS recovery or critical-rail recovery must not cause automatic energization of K_BATx."
		(exclude_from_sim no)
		(at 12 198 0)
		(effects (font (size 1.16 1.16)) (justify left))
		(uuid "ctrl-reserve-00000023-0000-4000-8000-000000000104")
	)

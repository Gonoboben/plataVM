	(title_block
		(title "23_MCU_CORE - control processor functional boundary")
		(date "2026-07-16")
		(rev "B2")
		(company "Gonoboben/plataVM")
		(comment 1 "V1.6 MCU family and internal CAN-FD ownership accepted")
		(comment 2 "STM32G4 family preliminary; package, memory, clock, ADC and footprints remain TBD")
	)
	(lib_symbols)
	(text "23_MCU_CORE - PURPOSE\nDefines the central normal-control processor boundary on PCB-B.\nThe MCU performs command processing, diagnostics, logging, RS-485 protocol and internal CAN-FD management.\nIt is not required for EXT_KILL actuation or local channel protection."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.24 1.24)) (justify left))
		(uuid "mcu-v16-23-101")
	)
	(text "MCU BASELINE\nPreliminary family: STM32G4. Final part/package follows pin count, ADC accuracy, memory and peripheral review.\nRequired functions include independent watchdog interaction, CRC, DMA, external isolated RS-485 and one internal CAN-FD controller.\nNo part number or footprint is selected."
		(exclude_from_sim no)
		(at 12 70 0)
		(effects (font (size 1.14 1.14)) (justify left))
		(uuid "mcu-v16-23-102")
	)
	(text "COMMUNICATION OWNERSHIP\nRS485_LOGIC serves the external 115200 bit/s addressed binary link.\nCAN_INT_LOGIC serves normal PCB-C/D/E commands, setpoints and detailed telemetry.\nDirect SAFE/HARD_OFF lines and board-fault summaries bypass CAN-FD data transport."
		(exclude_from_sim no)
		(at 12 132 0)
		(effects (font (size 1.12 1.12)) (justify left))
		(uuid "mcu-v16-23-103")
	)
	(text "SAFETY LIMIT\nFirmware may log EXT_KILL and faults but cannot block or clear the hardware safety path.\nCommunication loss must not disable local protection. BMS or critical-rail recovery cannot automatically energize K_BATx.\nWELDED_CONTACT and HARD_OFF_FAILED block restart."
		(exclude_from_sim no)
		(at 12 198 0)
		(effects (font (size 1.10 1.10)) (justify left))
		(uuid "mcu-v16-23-104")
	)

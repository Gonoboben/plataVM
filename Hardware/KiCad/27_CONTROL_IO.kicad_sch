	(paper "A3")
	(title_block
		(title "27_CONTROL_IO - interboard control and diagnostics boundary")
		(date "2026-07-15")
		(rev "B2")
		(company "Gonoboben/plataVM")
		(comment 1 "Interface consistency: canonical PCB-A and PCB-C logical ports")
		(comment 2 "No GPIO expander, ADC, mux, serializer, isolator, level shifter, connector or footprint selected")
	)
	(lib_symbols)
	(text "27_CONTROL_IO - PURPOSE\nDefines logical commands and diagnostic groups between PCB-B and PCB-A/C/D/E.\nThis sheet does not choose parallel versus serialized transport and does not allocate MCU pins.\nEvery output must have a safe default during reset, brownout, unplugged interface and loss of firmware execution."
		(exclude_from_sim no)
		(at 12 12 0)
		(effects (font (size 1.22 1.22)) (justify left))
		(uuid "ctrl-reserve-00000027-0000-4000-8000-000000000101")
	)
	(text "PCB-A BFE BOUNDARY\nBAT1/2_MAIN_SW_EN and BAT1/2_BALANCE_SW_EN default OFF.\nBAT1/2_HOLD_LOOP_OPEN_CMD and PACK_BUS_DISCHARGE_EN are normal-control outputs.\nEXT_KILL_HW_CHAIN bypasses this normal-control zone."
		(exclude_from_sim no)
		(at 12 62 0)
		(effects (font (size 1.08 1.08)) (justify left))
		(uuid "ctrl-reserve-00000027-0000-4000-8000-000000000102")
	)
	(text "PCB-C POWER_12V CONTRACT\nOutputs: P12_CH_EN[1..11], P12_GROUP_SAFE_OFF, P12_GROUP_HARD_OFF.\nInputs: P12_CH_FAULT_N[1..14], P12_CH_ISENSE[1..14], P12_BOARD_TEMP, P12_INPUT_VSENSE, P12_BOARD_FAULT_N.\nCH12..CH14 are Always-On monitored but remain subject to SAFE/HARD_OFF."
		(exclude_from_sim no)
		(at 12 112 0)
		(effects (font (size 1.08 1.08)) (justify left))
		(uuid "ctrl-reserve-00000027-0000-4000-8000-000000000103")
	)
	(text "PCB-D / PCB-E CONTRACTS PENDING DETAIL\nPCB-D: 5V_SYS_EN, P5_OUT_EN[1..7], P5_GROUP_SAFE_OFF, P5_GROUP_HARD_OFF and diagnostics.\nPCB-E: LIGHT_BRANCH_EN, LED_PWM[1..6], LIGHT_GROUP_HARD_OFF and diagnostics.\nTheir exact ports will be aligned during separate interface-consistency stages."
		(exclude_from_sim no)
		(at 12 168 0)
		(effects (font (size 1.08 1.08)) (justify left))
		(uuid "ctrl-reserve-00000027-0000-4000-8000-000000000104")
	)
	(text "TRANSPORT POLICY\nCTRL_B_TO_C_P12 and DIAG_C_TO_B_P12 remain logical grouped boundaries.\nDirect parallel, muxed analog or local serialized transport is not selected.\nExternal isolated RS-485 is not automatically used as an internal interboard link."
		(exclude_from_sim no)
		(at 12 224 0)
		(effects (font (size 1.08 1.08)) (justify left))
		(uuid "ctrl-reserve-00000027-0000-4000-8000-000000000105")
	)

	(uuid "b708645d-08b4-4947-a3dd-69ae73aaddfc")
	(paper "A3")
	(title_block
		(title "27_CONTROL_IO - interboard control and diagnostics boundary")
		(date "2026-07-15")
		(rev "B4")
		(company "Gonoboben/plataVM")
		(comment 1 "Interface consistency: canonical logical ports for PCB-A/C/D/E")
		(comment 2 "No GPIO expander, ADC, mux, serializer, isolator, level shifter, connector or footprint selected")
	)
	(lib_symbols)
	(text "PCB-D POWER_5V CONTRACT\nControls: 5V_SYS_EN, P5_OUT_EN[1..7], P5_GROUP_SAFE_OFF, P5_GROUP_HARD_OFF.\nDiagnostics: P5_OUT_FAULT_N[1..10], P5_OUT_ISENSE[1..10], 5V_SYS_VSENSE, 5V_SYS_TOTAL_ISENSE, P5_BOARD_TEMP, P5_BOARD_FAULT_N."
		(exclude_from_sim no)
		(at 12 118 0)
		(effects
			(font
				(size 1.02 1.02)
			)
			(justify left)
		)
		(uuid "0c91b414-00c8-4cef-9f7a-3ca2f144b203")
	)
	(text "27_CONTROL_IO - PURPOSE\nDefines logical commands and diagnostics between PCB-B and PCB-A/C/D/E.\nNo parallel-versus-serialized transport or MCU pin allocation is selected.\nEvery command requires deterministic safe behavior during reset, brownout, unplugged interface and lost firmware."
		(exclude_from_sim no)
		(at 12 12 0)
		(effects
			(font
				(size 1.16 1.16)
			)
			(justify left)
		)
		(uuid "27dc6c0d-9d6e-44d3-839f-01a128b00494")
	)
	(text "PCB-A / PCB-C CONTRACTS\nPCB-A canonical BFE controls and diagnostics remain unchanged.\nPCB-C controls: P12_CH_EN[1..11], P12_GROUP_SAFE_OFF, P12_GROUP_HARD_OFF.\nPCB-C diagnostics: P12_CH_FAULT_N[1..14], P12_CH_ISENSE[1..14], P12_INPUT_VSENSE, P12_BOARD_TEMP, P12_BOARD_FAULT_N."
		(exclude_from_sim no)
		(at 12 62 0)
		(effects
			(font
				(size 1.02 1.02)
			)
			(justify left)
		)
		(uuid "5f12742c-4159-4918-b347-37fdc78a78b0")
	)
	(text "TRANSPORT POLICY\nGrouped links remain logical boundaries. Direct parallel, muxed analog or local serialized transport is not selected.\nExternal isolated RS-485 is not automatically used as an internal interboard link.\nNo diagnostic transport participates in SAFE/HARD_OFF execution."
		(exclude_from_sim no)
		(at 12 226 0)
		(effects
			(font
				(size 1.02 1.02)
			)
			(justify left)
		)
		(uuid "7f432480-fd40-4bc7-abd3-3d8735bc1f61")
	)
	(text "PCB-E LIGHT_POWER CONTRACT\nControls: LIGHT_BRANCH_EN, LED_PWM[1..6], LIGHT_GROUP_HARD_OFF.\nDiagnostics: LED_FAULT_N[1..6], LED_ISENSE[1..6], LIGHT_INPUT_VSENSE, LIGHT_BOARD_TEMP, LIGHT_BOARD_FAULT_N.\nAll LED commands default OFF; diagnostic transport cannot delay HARD_OFF."
		(exclude_from_sim no)
		(at 12 174 0)
		(effects
			(font
				(size 1.02 1.02)
			)
			(justify left)
		)
		(uuid "d5884cd2-9fd3-4c90-bb5c-e862658781be")
	)

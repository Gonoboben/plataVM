	(paper "A3")
	(title_block
		(title "27_CONTROL_IO - interboard control and diagnostics boundary")
		(date "2026-07-15")
		(rev "B3")
		(company "Gonoboben/plataVM")
		(comment 1 "Interface consistency: canonical PCB-A, PCB-C and PCB-D logical ports")
		(comment 2 "No GPIO expander, ADC, mux, serializer, isolator, level shifter, connector or footprint selected")
	)
	(lib_symbols)
	(text "27_CONTROL_IO - PURPOSE\nDefines logical commands and diagnostics between PCB-B and PCB-A/C/D/E.\nThis sheet does not choose parallel versus serialized transport and does not allocate MCU pins.\nEvery command has a deterministic safe default during reset, brownout, unplugged interface and loss of firmware execution."
		(exclude_from_sim no)
		(at 12 12 0)
		(effects (font (size 1.18 1.18)) (justify left))
		(uuid "ctrl-reserve-00000027-0000-4000-8000-000000000101")
	)
	(text "PCB-A / PCB-C CONTRACTS\nPCB-A canonical BFE controls and diagnostics remain unchanged.\nPCB-C controls: P12_CH_EN[1..11], P12_GROUP_SAFE_OFF, P12_GROUP_HARD_OFF.\nPCB-C diagnostics: P12_CH_FAULT_N[1..14], P12_CH_ISENSE[1..14], P12_INPUT_VSENSE, P12_BOARD_TEMP, P12_BOARD_FAULT_N."
		(exclude_from_sim no)
		(at 12 62 0)
		(effects (font (size 1.06 1.06)) (justify left))
		(uuid "ctrl-reserve-00000027-0000-4000-8000-000000000102")
	)
	(text "PCB-D POWER_5V CONTRACT\nOutputs: 5V_SYS_EN, P5_OUT_EN[1..7], P5_GROUP_SAFE_OFF, P5_GROUP_HARD_OFF.\nInputs: P5_OUT_FAULT_N[1..10], P5_OUT_ISENSE[1..10], 5V_SYS_VSENSE, 5V_SYS_TOTAL_ISENSE, P5_BOARD_TEMP, P5_BOARD_FAULT_N.\nOUT8..OUT10 are Always-On monitored but remain subject to SAFE/HARD_OFF."
		(exclude_from_sim no)
		(at 12 118 0)
		(effects (font (size 1.06 1.06)) (justify left))
		(uuid "ctrl-reserve-00000027-0000-4000-8000-000000000103")
	)
	(text "PCB-E CONTRACT PENDING DETAIL\nPCB-E currently exposes CTRL_B_TO_E_LIGHT, DIAG_E_TO_B_LIGHT and LIGHT_GROUP_HARD_OFF.\nExact LED control and diagnostic ports will be aligned during the PCB-E interface-consistency stage."
		(exclude_from_sim no)
		(at 12 178 0)
		(effects (font (size 1.08 1.08)) (justify left))
		(uuid "ctrl-reserve-00000027-0000-4000-8000-000000000104")
	)
	(text "TRANSPORT POLICY\nGrouped links remain logical boundaries. Direct parallel, muxed analog or local serialized transport is not selected.\nExternal isolated RS-485 is not automatically used as an internal interboard link.\nDiagnostic transport cannot block SAFE/HARD_OFF."
		(exclude_from_sim no)
		(at 12 226 0)
		(effects (font (size 1.06 1.06)) (justify left))
		(uuid "ctrl-reserve-00000027-0000-4000-8000-000000000105")
	)

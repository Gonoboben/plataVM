	(uuid "ctrl-reserve-0000-4000-8000-000000000027")
	(paper "A3")
	(title_block
		(title "27_CONTROL_IO - interboard control and diagnostics boundary")
		(date "2026-07-15")
		(rev "B0")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A/B: BFE, POWER_12V, POWER_5V and LIGHT control/diagnostic groups")
		(comment 2 "No GPIO expander, ADC, mux, serializer, isolator, level shifter, connector or footprint selected")
	)
	(lib_symbols)
	(text "27_CONTROL_IO - PURPOSE\nDefines logical commands and diagnostic groups between PCB-B and PCB-A/C/D/E.\nThis sheet does not choose parallel versus serialized transport and does not allocate MCU pins.\nEvery output must have a safe default during reset, brownout, unplugged interface and loss of firmware execution."
		(exclude_from_sim no)
		(at 12 12 0)
		(effects (font (size 1.26 1.26)) (justify left))
		(uuid "ctrl-reserve-00000027-0000-4000-8000-000000000101")
	)
	(text "PCB-A BFE CONTROL OUTPUTS\nBAT1/2_MAIN_SW_EN default OFF; BAT1/2_BALANCE_SW_EN default OFF.\nBAT1/2_HOLD_LOOP_OPEN_CMD provide normal remote-off requests; PACK_BUS_DISCHARGE_EN is controlled with thermal limits TBD.\nEXT_KILL_HW_CHAIN bypasses normal MCU-controlled I/O and is not generated by this normal-control zone."
		(exclude_from_sim no)
		(at 12 62 0)
		(effects (font (size 1.12 1.12)) (justify left))
		(uuid "ctrl-reserve-00000027-0000-4000-8000-000000000102")
	)
	(text "PCB-A BFE DIAGNOSTIC INPUTS\nBAT1/2_PRESENT, BAT1/2_VSENSE, BAT1/2_ISENSE, PACK_BUS_VSENSE and BFE/balance/discharge fault groups are received here.\nAnalog versus digitized transport, ranges, filtering and reference-ground method remain TBD.\nDiagnostics cannot be required for EXT_KILL action."
		(exclude_from_sim no)
		(at 12 114 0)
		(effects (font (size 1.12 1.12)) (justify left))
		(uuid "ctrl-reserve-00000027-0000-4000-8000-000000000103")
	)
	(text "PCB-C / PCB-D / PCB-E CONTROL\nP12_CH_EN[1..11], P12_GROUP_SAFE_OFF, P12_GROUP_HARD_OFF;\n5V_SYS_EN, P5_OUT_EN[1..7], P5_GROUP_SAFE_OFF, P5_GROUP_HARD_OFF;\nLIGHT_BRANCH_EN, LED_PWM[1..6], LIGHT_GROUP_HARD_OFF.\nAlways-On channels remain monitored but are still subject to board protection, SAFE and HARD_OFF."
		(exclude_from_sim no)
		(at 12 170 0)
		(effects (font (size 1.10 1.10)) (justify left))
		(uuid "ctrl-reserve-00000027-0000-4000-8000-000000000104")
	)
	(text "POWER-BOARD DIAGNOSTICS\nReceive channel fault/current groups, input/bus voltage, total current, board temperature and board fault from PCB-C/D/E.\nPhysical packing may be direct parallel, muxed analog or local digital I/O after a separate pin-count/EMC/reliability decision.\nExternal isolated RS-485 is not automatically reused as the internal interboard interface."
		(exclude_from_sim no)
		(at 12 224 0)
		(effects (font (size 1.10 1.10)) (justify left))
		(uuid "ctrl-reserve-00000027-0000-4000-8000-000000000105")
	)

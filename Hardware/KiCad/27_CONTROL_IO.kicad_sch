		(title "27_CONTROL_IO - direct safety and CAN-FD data boundary")
		(date "2026-07-16")
		(rev "C1")
		(company "Gonoboben/plataVM")
		(comment 1 "V1.6 transport resolved: direct PCB-A and hardware safety/fault lines plus CAN-FD data objects")
		(comment 2 "No GPIO expander, ADC, transceiver, isolator, connector or footprint selected")
	)
	(lib_symbols)
	(text "27_CONTROL_IO - PURPOSE\nDefines direct critical commands/measurements and hardware safety lines.\nNormal PCB-C/D/E channel commands and detailed diagnostics are CAN-FD data objects, not mandatory individual interboard pins.\nAll direct outputs have deterministic safe defaults."
		(exclude_from_sim no)
		(at 12 12 0)
		(effects (font (size 1.20 1.20)) (justify left))
		(uuid "cio-v16-27-101")
	)
	(text "PCB-A DIRECT CONTRACT\nOutputs: BAT1/2_MAIN_SW_EN, BAT1/2_BALANCE_SW_EN, BAT1/2_HOLD_LOOP_OPEN_CMD, PACK_BUS_DISCHARGE_EN.\nInputs: BAT1/2_PRESENT, BAT1/2_VSENSE, BAT1/2_ISENSE, PACK_BUS_VSENSE and canonical BFE/BALANCE faults.\nEXT_KILL hardware fanout is independent of this normal-control block."
		(exclude_from_sim no)
		(at 12 62 0)
		(effects (font (size 1.05 1.05)) (justify left))
		(uuid "cio-v16-27-102")
	)
	(text "PCB-C/D/E DIRECT HARDWARE CONTRACT\nPCB-C: P12_GROUP_SAFE_OFF, P12_GROUP_HARD_OFF, P12_BOARD_FAULT_N.\nPCB-D: P5_GROUP_SAFE_OFF, P5_GROUP_HARD_OFF, P5_BOARD_FAULT_N.\nPCB-E: LIGHT_GROUP_HARD_OFF, LIGHT_BOARD_FAULT_N.\nThese lines remain operational during CAN-FD loss."
		(exclude_from_sim no)
		(at 12 130 0)
		(effects (font (size 1.06 1.06)) (justify left))
		(uuid "cio-v16-27-103")
	)
	(text "CAN-FD DATA-OBJECT CONTRACT\nP12: channel enables, current/fault/status, input voltage and temperature.\nP5: converter/output enables, current/fault/status, bus voltage/current and temperature.\nLIGHT: branch enable, brightness setpoints, current/open/short/status and temperature.\nLocal protection and local PWM generation remain on the destination boards."
		(exclude_from_sim no)
		(at 12 198 0)
		(effects (font (size 1.04 1.04)) (justify left))
		(uuid "cio-v16-27-104")
	)

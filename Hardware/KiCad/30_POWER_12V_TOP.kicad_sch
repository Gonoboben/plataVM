		(title "30_POWER_12V_TOP - PCB-C_POWER_12V")
		(date "2026-07-15")
		(rev "A1")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A: 14-channel 12V distribution")
		(comment 2 "No eFuse/high-side switch part numbers or footprints selected")
	)
	(lib_symbols)
	(text "30_POWER_12V_TOP - PCB-C_POWER_12V\nPurpose: define 14-channel 12V distribution, control and diagnostics boundaries.\nEach channel is preliminary 3 A continuous; final switch/protection topology TBD."
		(exclude_from_sim no)
		(at 12 10 0)
		(effects (font (size 1.55 1.55)) (justify left))
		(uuid "p12-text-0001")
	)
	(text "POWER INPUT\nPACK_BUS_P12_IN enters from PCB-A fanout.\nLocal input protection, reverse/transient protection and bulk capacitance are TBD.\nReturn reference is POWER_GND unless a dedicated sense return is defined."
		(exclude_from_sim no)
		(at 12 38 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "p12-text-0002")
	)
	(text "CONTROLLED CHANNELS\nCH1..CH11 are MCU-controlled through PCB-B.\nEach channel requires enable, protection and fault/status diagnostics.\nAssignments remain software-configurable."
		(exclude_from_sim no)
		(at 112 38 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "p12-text-0003")
	)
	(text "ALWAYS-ON MONITORED CHANNELS\nCH12..CH14 are Always-On monitored outputs.\nThey are not uncontrolled: protection, monitoring and HARD_OFF/SAFE behavior still apply.\nExact switching topology is TBD."
		(exclude_from_sim no)
		(at 222 38 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "p12-text-0004")
	)
	(text "OUTPUT PROTECTION\nPer-channel current limit/fuse/eFuse/high-side switch topology TBD.\nInductive and capacitive load behavior must be handled per channel.\nReverse current and load dump policy remain open."
		(exclude_from_sim no)
		(at 12 112 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "p12-text-0005")
	)
	(text "DIAGNOSTICS TO PCB-B\nChannel current/fault/status, Always-On monitoring, board temperature, input voltage.\nParallel vs serialized/muxed diagnostics remain TBD.\nNo MCU selection is made here."
		(exclude_from_sim no)
		(at 112 112 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "p12-text-0006")
	)
	(text "EXTERNAL CONNECTORS\n12V output connector family, pin count, wire gauge and grouping are TBD.\nHigh-current returns must be sized and routed with the output conductors.\nConnector pinout is not frozen by this sheet."
		(exclude_from_sim no)
		(at 222 112 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "p12-text-0007")
	)
	(text "SAFE STATES\nHARD_OFF/EXT_KILL must remove or block load power according to system sequence.\nFaulted channel must not disable unrelated channels unless group protection requires it.\nThermal limits must be checked before schematic freeze."
		(exclude_from_sim no)
		(at 12 190 0)
		(effects (font (size 1.25 1.25)) (justify left))
		(uuid "p12-text-0008")
	)

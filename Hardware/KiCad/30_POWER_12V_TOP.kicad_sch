	(lib_symbols)
	(text "30_POWER_12V_TOP - DETAILED HIERARCHY MAP\nPCB-C receives PACK_BUS_P12_IN directly from PCB-A and distributes fourteen protected 12 V outputs.\nCH1..CH11 are normally controlled from PCB-B; CH12..CH14 are Always-On monitored.\nAll channels remain subject to protection, SAFE_OFF and HARD_OFF."
		(exclude_from_sim no)
		(at 12 12 0)
		(effects (font (size 1.36 1.36)) (justify left))
		(uuid "p12-top-00000030-0000-4000-8000-000000000101")
	)
	(text "SUB-SHEETS 31..33\n31_POWER_12V_INPUT_PROTECTION: branch input, transient/reverse protection boundary, bulk energy and input sensing\n32_POWER_12V_CHANNEL_TEMPLATE: single-channel functional contract for protection, control and diagnostics\n33_POWER_12V_CH1_CH7: seven MCU-controlled channel instances"
		(exclude_from_sim no)
		(at 12 72 0)
		(effects (font (size 1.18 1.18)) (justify left))
		(uuid "p12-top-00000030-0000-4000-8000-000000000102")
	)
	(text "SUB-SHEETS 34..36\n34_POWER_12V_CH8_CH14: CH8..CH11 controlled plus CH12..CH14 Always-On monitored\n35_POWER_12V_DIAGNOSTICS: channel and board diagnostic aggregation toward PCB-B\n36_POWER_12V_CONNECTORS: logical output/return groups and protected test boundaries"
		(exclude_from_sim no)
		(at 168 72 0)
		(effects (font (size 1.18 1.18)) (justify left))
		(uuid "p12-top-00000030-0000-4000-8000-000000000103")
	)
	(text "ARCHITECTURAL CONSTRAINTS\n- nominal continuous channel requirement: 3 A per output, subject to total branch and thermal calculations;\n- no channel current passes through PCB-B;\n- a faulted channel should remain isolated from unrelated channels unless branch protection requires wider shutdown;\n- inductive/capacitive inrush, reverse current and load dump policies remain TBD;\n- no eFuse/high-side switch, connector, footprint, BOM or layout is selected."
		(exclude_from_sim no)
		(at 12 150 0)
		(effects (font (size 1.12 1.12)) (justify left))
		(uuid "p12-top-00000030-0000-4000-8000-000000000104")
	)
	(text "NEXT CONTROLLED PASS\nAfter hierarchy review, check exact PCB-B <-> PCB-C control and diagnostic names against Docs/INTERBOARD_INTERFACES.md.\nThe choice between direct parallel, muxed analog or local serialized diagnostics remains a later decision."
		(exclude_from_sim no)
		(at 12 222 0)
		(effects (font (size 1.12 1.12)) (justify left))
		(uuid "p12-top-00000030-0000-4000-8000-000000000105")
	)

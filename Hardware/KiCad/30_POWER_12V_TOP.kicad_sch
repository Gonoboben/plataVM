	(lib_symbols)
	(text "CONTROL INPUTS:\nP12_CH_EN[1..11], P12_GROUP_SAFE_OFF, P12_GROUP_HARD_OFF.\nAlways-On monitored CH12..CH14 still must be removable by protection, SAFE and HARD_OFF."

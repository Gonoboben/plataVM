		(uuid "31e90658-9b2c-49d7-97dd-45f3cc4fd5bc")
	)
	(text "DIAGNOSTICS OUTPUTS:\nP12_CH_FAULT_N[1..14], P12_CH_ISENSE[1..14], P12_BOARD_TEMP, P12_INPUT_VSENSE, P12_BOARD_FAULT_N.\nPhysical interface may be parallel IO or local IO/ADC plus internal digital bus; TBD."
		(exclude_from_sim no)

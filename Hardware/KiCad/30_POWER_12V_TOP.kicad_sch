		(title "30_POWER_12V_TOP - PCB-C_POWER_12V")
		(date "2026-07-15")
		(rev "A4")
		(company "Gonoboben/plataVM")
		(comment 1 "Interface consistency: exact PCB-B/PCB-C control and diagnostic bus names")
		(comment 2 "Detailed hierarchy 31..36; no components, connectors or footprints selected")
	)
	(lib_symbols)
	(text "CANONICAL INTERBOARD CONTRACT\nControls: P12_CH_EN[1..11], P12_GROUP_SAFE_OFF, P12_GROUP_HARD_OFF.\nDiagnostics: P12_CH_FAULT_N[1..14], P12_CH_ISENSE[1..14], P12_BOARD_TEMP, P12_INPUT_VSENSE, P12_BOARD_FAULT_N.\nCTRL_B_TO_C_P12 and DIAG_C_TO_B_P12 remain logical grouped boundaries; physical packing is TBD."
		(exclude_from_sim no)
		(at 12 150 0)
		(effects
			(font
				(size 1.1 1.1)
			)
			(justify left)
		)
		(uuid "0abbea81-ed02-4fb3-9c4c-a598cd6d86ea")
	)
	(text "SUB-SHEETS 31..33\n31_POWER_12V_INPUT_PROTECTION: branch input, transient/reverse protection boundary, bulk energy and input sensing\n32_POWER_12V_CHANNEL_TEMPLATE: single-channel functional contract for protection, control and diagnostics\n33_POWER_12V_CH1_CH7: seven MCU-controlled channel instances"
		(exclude_from_sim no)
		(at 12 72 0)
		(effects
			(font
				(size 1.18 1.18)
			)
			(justify left)
		)
		(uuid "260de87e-1d94-43d5-a19e-c7f05aebd0a7")
	)
	(text "30_POWER_12V_TOP - DETAILED HIERARCHY MAP\nPCB-C receives PACK_BUS_P12_IN directly from PCB-A and distributes fourteen protected 12 V outputs.\nCH1..CH11 are normally controlled from PCB-B; CH12..CH14 are Always-On monitored.\nAll channels remain subject to protection, SAFE_OFF and HARD_OFF."
		(exclude_from_sim no)
		(at 12 12 0)
		(effects
			(font
				(size 1.36 1.36)
			)
			(justify left)
		)
		(uuid "3df1bb43-3a1b-4b69-b097-b8c4b99f5bc8")
	)
	(text "ARCHITECTURAL CONSTRAINTS\nNominal continuous requirement is 3 A per output subject to total branch and thermal calculations.\nNo channel current passes through PCB-B. CH12..CH14 remain subject to SAFE/HARD_OFF.\nProtection topology, diagnostic transport, connectors, footprints, BOM and layout remain unselected."
		(exclude_from_sim no)
		(at 12 214 0)
		(effects
			(font
				(size 1.1 1.1)
			)
			(justify left)
		)
		(uuid "61062683-0a49-4e2a-9a89-d875a8ccedcb")
	)
	(text "SUB-SHEETS 34..36\n34_POWER_12V_CH8_CH14: CH8..CH11 controlled plus CH12..CH14 Always-On monitored\n35_POWER_12V_DIAGNOSTICS: channel and board diagnostic aggregation toward PCB-B\n36_POWER_12V_CONNECTORS: logical output/return groups and protected test boundaries"
		(exclude_from_sim no)
		(at 168 72 0)
		(effects
			(font
				(size 1.18 1.18)
			)
			(justify left)
		)

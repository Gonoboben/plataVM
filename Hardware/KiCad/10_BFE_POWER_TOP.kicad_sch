	(title_block
		(title "10_BFE_POWER_TOP - PCB-A_BFE_POWER")
		(date "2026-07-15")
		(rev "A1")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A: BFE branches, PACK_BUS and final HARD_OFF actuators")
		(comment 2 "No K_BATx/MAIN_SWx/current sensor part numbers selected")
	)
	(lib_symbols)
	(text "10_BFE_POWER_TOP - PCB-A_BFE_POWER\nPurpose: define PCB-A functional zones, power flow and safety actuator boundaries.\nPCB-A receives power after external K_BATx via SN-176A-12 and creates PACK_BUS."
		(exclude_from_sim no)
		(at 12 10 0)
		(effects (font (size 1.55 1.55)) (justify left))
		(uuid "bfe-a-text-0001")
	)
	(text "BATTERY INPUTS\nBAT1_SN176_POWER -> BFE_1 input protection / measurement / MAIN_SW1.\nBAT2_SN176_POWER -> BFE_2 input protection / measurement / MAIN_SW2.\nBranches must remain symmetric until PACK_BUS combining point."
		(exclude_from_sim no)
		(at 12 38 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "bfe-a-text-0002")
	)
	(text "BFE_1 / BFE_2 POWER PATHS\nSN-176A-12 BAT+ enters after external K_BATx.\nMAIN_SWx is electronic power path TBD, not a replacement for K_BATx.\nCurrent/voltage measurement topology remains TBD."
		(exclude_from_sim no)
		(at 112 38 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "bfe-a-text-0003")
	)
	(text "PACK_BUS CREATION\nBFE_1 and BFE_2 combine only after their protected input paths.\nNo central K_MAIN is introduced.\nPACK_BUS fanout must be star wiring or calculated bus, not serial feed through PCB-B."
		(exclude_from_sim no)
		(at 222 38 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "bfe-a-text-0004")
	)
	(text "REMOTE_OFF / EXT_KILL FINAL ACTUATORS\nPCB-A contains final elements that open BAT1/BAT2 hold loops.\nEXT_KILL hardware path must not depend on MCU firmware.\nREMOTE_OFF_NC and EXT_KILL_NC are functional blocks, component choice TBD."
		(exclude_from_sim no)
		(at 12 112 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "bfe-a-text-0005")
	)
	(text "DECK_BALANCE\nBALANCE_SW1/BALANCE_SW2 and R_BALx are controlled only after work sequence.\nDeck balancing is MCU-supervised and must not bypass K_BATx safety behavior.\nFinal resistor/switch ratings are TBD."
		(exclude_from_sim no)
		(at 112 112 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "bfe-a-text-0006")
	)
	(text "DIAGNOSTICS TO PCB-B\nBAT1/2_PRESENT, BAT1/2_VSENSE, BAT1/2_ISENSE, PACK_BUS_VSENSE,\nMAIN_SWx status, balance status, hold-loop actuator status, temperatures/faults TBD."
		(exclude_from_sim no)
		(at 222 112 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "bfe-a-text-0007")
	)
	(text "SAFE STATES\nLoss of K_BATx coil supply opens external K_BATx and requires manual LOCAL_START.\nPCB-A HARD_OFF opens hold loops and disables electronic power paths.\nWelded main contact remains a fault to detect, not a normal control mode."
		(exclude_from_sim no)
		(at 12 190 0)
		(effects (font (size 1.25 1.25)) (justify left))
		(uuid "bfe-a-text-0008")
	)

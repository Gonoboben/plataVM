		(title "10_BFE_POWER_TOP - PCB-A_BFE_POWER")
		(date "2026-07-15")
		(rev "A2")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A: BFE detailed hierarchy map")
		(comment 2 "Sub-sheets 11..19 define functional boundaries only")
	)
	(lib_symbols)
	(text "ARCHITECTURAL CONSTRAINTS\n- no K_MAIN; PACK_BUS is created on PCB-A and fanned out by star wiring or calculated bus;\n- high current does not pass through PCB-B_CTRL_RESERVE;\n- K_BATx is monostable in external battery housing; PCB-A only interrupts hold-loop return;\n- EXT_KILL final path must not depend on MCU firmware;\n- BFE_1 and BFE_2 remain symmetric unless an explicit ADR changes that."
		(exclude_from_sim no)
		(at 12 132 0)
		(effects
			(font
				(size 1.25 1.25)
			)
			(justify left)
		)
		(uuid "152658f4-01e6-4c51-978e-1db7648716ae")
	)
	(text "SUB-SHEETS\n11_BATTERY_INPUT_1: AKB_1 / SN-176A-12 BFE-side boundary\n12_BATTERY_INPUT_2: AKB_2 / SN-176A-12 BFE-side boundary\n13_MAIN_PATH_1: MAIN_SW1 functional branch\n14_MAIN_PATH_2: MAIN_SW2 functional branch\n15_DECK_BALANCE: controlled deck-side balance path"
		(exclude_from_sim no)
		(at 12 62 0)
		(effects
			(font
				(size 1.35 1.35)
			)
			(justify left)
		)
		(uuid "a4769320-f283-4ac3-8f36-b99a206a5894")
	)
	(text "SUB-SHEETS CONTINUED\n16_PACK_BUS_AND_DISCHARGE: PACK_BUS creation, fanout and discharge\n17_REMOTE_OFF_AND_EXT_KILL: K_BATx hold-loop final NC actuators\n18_BATTERY_MEASUREMENTS: voltage/current/status measurement groups\n19_BFE_CONNECTORS_TESTPOINTS: connector groups and service testpoints"
		(exclude_from_sim no)
		(at 150 62 0)
		(effects
			(font
				(size 1.35 1.35)
			)
			(justify left)
		)
		(uuid "dfdfd589-ca4e-4226-b185-7eec1e95f5d3")
	)
	(text "10_BFE_POWER_TOP - DETAILED HIERARCHY MAP\nPCB-A_BFE_POWER contains two symmetric battery front-end branches, PACK_BUS creation,\nREMOTE_OFF/EXT_KILL final actuators, DECK_BALANCE, measurements and connector/test boundaries.\nThis top sheet maps functional sub-sheets; it does not select components, footprints or PCB layout."
		(exclude_from_sim no)
		(at 12 12 0)
		(effects
			(font
				(size 1.5 1.5)
			)
			(justify left)
		)
		(uuid "e42c6a41-0e59-46de-ad83-046bdd98a99e")
	)
	(text "NEXT DETAIL PASS\nAfter this architecture map is checked in KiCad, the next engineering step is to replace selected TBD blocks\ninside 11..19 with actual schematic symbols and calculated values, starting from the battery input and hold-loop paths."
		(exclude_from_sim no)

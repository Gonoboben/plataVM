	(lib_symbols)
	(text "SYSTEM POWER FLOW:\nBAT1/BAT2 -> PCB-A_BFE_POWER -> PACK_BUS -> PCB-C_POWER_12V / PCB-D_POWER_5V / PCB-E_LIGHT_POWER / PCB-B_CTRL_RESERVE.\nPCB-B provides MCU, critical power, EMG, RS-485 and control/diagnostics."

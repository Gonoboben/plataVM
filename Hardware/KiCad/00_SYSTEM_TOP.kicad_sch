	)
	(lib_symbols)
	(text "00_SYSTEM_TOP - SYSTEM ARCHITECTURE LEVEL A\nPurpose: show power flow, control/diagnostic groups, safety paths\nand top-level hierarchical interface names.\nSource of truth: Docs/SCHEMATIC_ARCHITECTURE.md, Docs/INTERBOARD_INTERFACES.md, Docs/NET_NAMING_RULES.md."
		(exclude_from_sim no)
		(at 15 10 0)
		(effects
			(font
				(size 1.7 1.7)
			)
			(justify left)
		)
		(uuid "a31c6d57-73ed-4a15-b795-c5dbb2e73501")
	)
	(text "EXTERNAL BATTERY HOUSINGS\nAKB_1 / AKB_2: LiFePO4 4S24P -> autonomous BMS -> BAT_PROT -> fuse -> K_BATx -> SN-176A-12.\nNo active electronics, no raw branch, no digital BMS telemetry in battery housings."
		(exclude_from_sim no)
		(at 12 32 0)
		(effects
			(font
				(size 1.45 1.45)
			)
			(justify left)
		)
		(uuid "9b0c86f6-10c4-4b41-b5ac-9d8aa0480e01")
	)
	(text "PCB-A_BFE_POWER\nTwo symmetric BFE branches, MAIN_SW1/2, DECK_BALANCE, measurements,\nREMOTE_OFF_NC final elements, EXT_KILL final hardware path, PACK_BUS creation."
		(exclude_from_sim no)
		(at 120 32 0)
		(effects
			(font
				(size 1.45 1.45)
			)
			(justify left)
		)
		(uuid "1c516bd0-5371-4671-9bdd-6248b52ba160")
	)
	(text "PACK_BUS FANOUT\nPACK_BUS is distributed from PCB-A by star wiring or calculated bus.\nNo central K_MAIN. No sequential high-current feed through PCB-B_CTRL_RESERVE."
		(exclude_from_sim no)
		(at 80 82 0)
		(effects
			(font
				(size 1.45 1.45)
			)
			(justify left)
		)
		(uuid "98fa353c-c5dc-401a-91aa-065f1a785e9a")
	)
	(text "PCB-B_CTRL_RESERVE\nMCU, fault manager, watchdog/supervisor, EMG/KEEP_ALIVE, 5V_CRIT, 3V3_CRIT,\nisolated RS-485, EXT_KILL input/logic and control/diagnostic interfaces."
		(exclude_from_sim no)
		(at 12 128 0)
		(effects
			(font
				(size 1.45 1.45)
			)
			(justify left)
		)
		(uuid "26a6a376-9ea7-49ca-9e5b-85cf659e741f")
	)
	(text "LOAD POWER MODULES\nPCB-C_POWER_12V: CH1..CH14.\nPCB-D_POWER_5V: 5V_SYS and 5V_OUT1..10.\nPCB-E_LIGHT_POWER: six independent LED drivers."
		(exclude_from_sim no)
		(at 150 128 0)
		(effects
			(font
				(size 1.45 1.45)
			)
			(justify left)
		)
		(uuid "2df2748a-b8c3-40c9-9b76-73c22d9851f2")
	)
	(text "SAFETY / GROUND RULES\n1. K_BATx opens on BMS protected output loss and does not auto-restart.\n2. EXT_KILL hardware path does not depend on MCU.\n3. POWER_GND, SIGNAL_GND, ISO_GND and CHASSIS remain separate until a\n   dedicated ground/chassis decision."
		(exclude_from_sim no)
		(at 12 184 0)
		(effects
			(font
				(size 1.35 1.35)
			)
			(justify left)
		)
		(uuid "95da9359-e9bc-475b-b195-7d328734e852")
	)

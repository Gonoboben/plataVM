	(title_block
		(title "50_LIGHT_POWER_TOP - PCB-E_LIGHT_POWER")
		(date "2026-07-15")
		(rev "A1")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A: six independent LED driver channels")
		(comment 2 "No LED driver part numbers or footprints selected")
	)
	(lib_symbols)
	(text "50_LIGHT_POWER_TOP - PCB-E_LIGHT_POWER\nPurpose: define six independent LED driver channels and diagnostics boundaries.\nTarget load: 6 x Epistar XY-J45, final electrical LED parameters and driver topology TBD."
		(exclude_from_sim no)
		(at 12 10 0)
		(effects (font (size 1.55 1.55)) (justify left))
		(uuid "light-text-0001")
	)
	(text "POWER INPUT\nPACK_BUS_LIGHT_IN enters from PCB-A fanout.\nLocal protection, filtering, inrush and bulk capacitance are TBD.\nNo TRACO target architecture is assumed."
		(exclude_from_sim no)
		(at 12 38 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "light-text-0002")
	)
	(text "LED DRIVER CHANNELS\nLED_DRV1..LED_DRV6 are independent onboard drivers.\nEach channel has enable/PWM, current regulation and fault reporting.\nTwo local thermal/power zones of three channels may be used inside PCB-E."
		(exclude_from_sim no)
		(at 112 38 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "light-text-0003")
	)
	(text "CONTROL FROM PCB-B\nLIGHT_BRANCH_EN, LED_PWM[1..6], driver enable/reset TBD.\nPWM levels, frequency and fail-safe default state are TBD.\nControl must support all channels off during HARD_OFF/SAFE."
		(exclude_from_sim no)
		(at 222 38 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "light-text-0004")
	)
	(text "DIAGNOSTICS TO PCB-B\nPer-channel LED current, open/short, driver fault and board temperature.\nAnalog vs digital diagnostics remains TBD.\nFault summary line may be added after driver topology selection."
		(exclude_from_sim no)
		(at 12 112 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "light-text-0005")
	)
	(text "LED OUTPUT CONNECTORS\nLED1..LED6 external wiring, connector family, wire gauge and polarity marking are TBD.\nHarness must handle thermal environment and LED current.\nOutput short/open detection must be testable."
		(exclude_from_sim no)
		(at 112 112 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "light-text-0006")
	)
	(text "THERMAL / EMC\nLED drivers and switching edges require local layout and filtering decisions.\nHeat sinking, copper area and temperature sensor placement are TBD.\nGround/chassis/shield treatment follows system EMC decision."
		(exclude_from_sim no)
		(at 222 112 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "light-text-0007")
	)
	(text "SAFE STATES\nDefault safe output is all LED channels off.\nSingle channel fault should not disable all lighting unless thermal/group safety requires it.\nHARD_OFF/EXT_KILL must force light power branch to safe state."
		(exclude_from_sim no)
		(at 12 190 0)
		(effects (font (size 1.25 1.25)) (justify left))
		(uuid "light-text-0008")
	)

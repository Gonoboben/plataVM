		(title "50_LIGHT_POWER_TOP - PCB-E_LIGHT_POWER")
		(date "2026-07-15")
		(rev "A2")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A/B: six independent LED-driver detailed hierarchy")
		(comment 2 "Sub-sheets 51..56 define functional boundaries only; no components selected")
	)
	(lib_symbols)
	(text "SUB-SHEETS 54..56\n54_LED_DRIVER_4_6: three independent driver-channel instances\n55_LIGHT_DIAGNOSTICS: per-channel and board-level diagnostic aggregation toward PCB-B\n56_LIGHT_CONNECTORS: logical LED output/return, harness and protected test boundaries"
		(exclude_from_sim no)
		(at 168 72 0)
		(effects
			(font
				(size 1.14 1.14)
			)
			(justify left)
		)
		(uuid "65c4d718-7721-4074-8d79-0427ccd1cf76")
	)
	(text "ARCHITECTURAL CONSTRAINTS\nDefault safe state is all LED channels OFF. A single channel fault should remain isolated unless thermal/group protection requires wider shutdown.\nDriver topology, conversion ratio, PWM level/frequency, thermal solution, connectors, footprints, BOM and layout remain unselected."
		(exclude_from_sim no)
		(at 12 218 0)
		(effects
			(font
				(size 1.08 1.08)
			)
			(justify left)
		)
		(uuid "7fb3d0d3-21d8-41b3-a380-d256f79406be")
	)
	(text "CANONICAL CONTROL / DIAGNOSTICS\nControls: LIGHT_BRANCH_EN, LED_PWM[1..6], LIGHT_GROUP_HARD_OFF.\nDiagnostics: LED_FAULT_N[1..6], LED_ISENSE[1..6], LIGHT_INPUT_VSENSE, LIGHT_BOARD_TEMP, LIGHT_BOARD_FAULT_N.\nCTRL_B_TO_E_LIGHT / DIAG_E_TO_B_LIGHT remain grouped logical boundaries; physical packing is TBD."
		(exclude_from_sim no)
		(at 12 150 0)
		(effects
			(font
				(size 1.06 1.06)
			)
			(justify left)
		)
		(uuid "9de4273c-0ad0-424e-9e87-d453026a7a31")
	)
	(text "SUB-SHEETS 51..53\n51_LIGHT_INPUT_PROTECTION: branch input, local protection/bulk-energy and input sensing boundaries\n52_LED_DRIVER_TEMPLATE: reusable single-channel control/regulation/protection/diagnostic contract\n53_LED_DRIVER_1_3: three independent driver-channel instances"
		(exclude_from_sim no)
		(at 12 72 0)
		(effects
			(font
				(size 1.14 1.14)
			)
			(justify left)
		)
		(uuid "eb47d0d7-9e8c-41b7-ae9e-5c0a77bc11c9")
	)
	(text "50_LIGHT_POWER_TOP - DETAILED HIERARCHY MAP\nPCB-E receives PACK_BUS_LIGHT_IN directly from PCB-A and drives six independent external LED loads.\nEach channel has independent PWM, current regulation, fault and current diagnostics.\nTwo local zones of three channels are allowed inside one PCB-E; no additional functional PCB is created."
		(exclude_from_sim no)
		(at 12 12 0)
		(effects
			(font
				(size 1.28 1.28)
			)
			(justify left)
		)
		(uuid "fcbb15b8-37ab-4f46-803c-ae08121d46ef")
	)

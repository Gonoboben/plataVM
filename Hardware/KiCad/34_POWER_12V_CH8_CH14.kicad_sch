	(paper "A3")
	(title_block
		(title "34_POWER_12V_CH8_CH14 - controlled and Always-On output group")
		(date "2026-07-15")
		(rev "B0")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A/B: CH8..CH11 controlled, CH12..CH14 Always-On monitored")
		(comment 2 "No switch, protection, sensor, suppression, connector or footprint selected")
	)
	(lib_symbols)
	(text "34_POWER_12V_CH8_CH14 - PURPOSE\nDefines seven independent channel instances based on sheet 32.\nCH8..CH11 have independent normal enables from PCB-B.\nCH12..CH14 are Always-On monitored in normal operation but remain protected and subject to SAFE/HARD_OFF."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.20 1.20)) (justify left))
		(uuid "power-12v-00000034-0000-4000-8000-000000000101")
	)
	(text "CONTROLLED CHANNELS CH8..CH11\nP12_CH_EN_8_11 represents four independent normal-control enables.\nReset, brownout and disconnected-control defaults must be OFF.\nP12_GROUP_SAFE_OFF and P12_GROUP_HARD_OFF override normal enables."
		(exclude_from_sim no)
		(at 12 76 0)
		(effects (font (size 1.14 1.14)) (justify left))
		(uuid "power-12v-00000034-0000-4000-8000-000000000102")
	)
	(text "ALWAYS-ON MONITORED CH12..CH14\nAlways-On means enabled during normal RUN without an MCU command; it does not mean unprotected or immune to shutdown.\nEach channel retains individual fault/current diagnostics and must turn off under board protection, SAFE_OFF or HARD_OFF.\nThe physical always-enabled implementation remains TBD."
		(exclude_from_sim no)
		(at 12 136 0)
		(effects (font (size 1.10 1.10)) (justify left))
		(uuid "power-12v-00000034-0000-4000-8000-000000000103")
	)
	(text "POWER / DIAGNOSTIC GROUPS\nAll channels draw from P12_PROTECTED_BUS and preserve individual output and diagnostic identity.\nP12_CH_FAULT_N_8_14 and P12_CH_ISENSE_8_14 feed sheet 35.\nLoad profiles, inrush, suppression and simultaneous-load thermal limits remain TBD."
		(exclude_from_sim no)
		(at 12 210 0)
		(effects (font (size 1.12 1.12)) (justify left))
		(uuid "power-12v-00000034-0000-4000-8000-000000000104")
	)

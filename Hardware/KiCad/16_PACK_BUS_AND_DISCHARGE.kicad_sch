	(title_block
		(title "16_PACK_BUS_AND_DISCHARGE - PACK_BUS creation")
		(date "2026-07-15")
		(rev "B1")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level B: PACK_BUS net groups and discharge logic")
		(comment 2 "No K_MAIN, no discharge component values, no busbar/wire gauge selected")
	)
	(lib_symbols)
	(text "16_PACK_BUS_AND_DISCHARGE - LEVEL B FUNCTIONAL NETS\nInputs from BFE branches: BFE1_SW_OUT and BFE2_SW_OUT.\nThese join the common PACK_BUS_NODE only after MAIN_SW1/MAIN_SW2 functional boundaries.\nPACK_BUS is then exported as separate fanout groups to CRIT, 12V, 5V and LIGHT modules."
		(exclude_from_sim no)
		(at 12 18 0)
		(effects (font (size 1.35 1.35)) (justify left))
		(uuid "bfe-lb-00000016-0000-4000-8000-000000000101")
	)
	(text "DISCHARGE FUNCTION\nPACK_BUS_DISCHARGE_EN commands the controlled discharge path.\nDIAG_PACK_BUS_V and DIAG_PACK_BUS_DISCH_STATUS report voltage and discharge state to PCB-B.\nDischarge shall be used by HARD_OFF after loads are removed and K_BAT hold loops are opened."
		(exclude_from_sim no)
		(at 12 78 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "bfe-lb-00000016-0000-4000-8000-000000000102")
	)
	(text "SAFE-STATE RULES\nNo central K_MAIN is allowed.\nPCB-B_CTRL_RESERVE must not be a high-current feed-through for PACK_BUS.\nPACK_BUS discharge element sizing, energy, timeout and thermal limits remain TBD.\nDo not add always-on loads here without CRIT/EMG budget analysis."
		(exclude_from_sim no)
		(at 12 138 0)
		(effects (font (size 1.25 1.25)) (justify left))
		(uuid "bfe-lb-00000016-0000-4000-8000-000000000103")
	)

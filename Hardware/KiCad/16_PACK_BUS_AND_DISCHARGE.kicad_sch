	(title_block
		(title "16_PACK_BUS_AND_DISCHARGE - PACK_BUS creation")
		(date "2026-07-15")
		(rev "A1")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A: PACK_BUS fanout and discharge boundary")
		(comment 2 "No central K_MAIN and no PCB-B high-current feed-through")
	)
	(lib_symbols)
	(text "16_PACK_BUS_AND_DISCHARGE - FUNCTIONAL PURPOSE\nMAIN_SW1_TO_PACK_BUS and MAIN_SW2_TO_PACK_BUS combine into PACK_BUS on PCB-A.\nPACK_BUS is distributed to PCB-B/PCB-C/PCB-D/PCB-E by star wiring or calculated bus.\nThere is no K_MAIN and no sequential high-current routing through PCB-B_CTRL_RESERVE."
		(exclude_from_sim no)
		(at 12 18 0)
		(effects (font (size 1.45 1.45)) (justify left))
		(uuid "bfe-dh-00000016-0000-4000-8000-000000000101")
	)
	(text "DISCHARGE / SAFE STATE\nPACK_BUS discharge is controlled and monitored.\nHARD_OFF must remove heavy loads, open hold loops, verify branch current decay and verify PACK_BUS discharge.\nDischarge element sizing, energy, timeout and thermal limits remain TBD."
		(exclude_from_sim no)
		(at 12 82 0)
		(effects (font (size 1.35 1.35)) (justify left))
		(uuid "bfe-dh-00000016-0000-4000-8000-000000000102")
	)
	(text "OPEN ITEMS\nBusbar/wire gauge, local capacitance, inrush, precharge need, discharge resistor, measurement divider and EMC return policy remain TBD.\nDo not add new always-on loads to PACK_BUS without CRIT/EMG analysis."
		(exclude_from_sim no)
		(at 12 142 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "bfe-dh-00000016-0000-4000-8000-000000000103")
	)

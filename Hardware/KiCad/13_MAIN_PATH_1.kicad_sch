		(title "13_MAIN_PATH_1 - BFE_1 main electronic path")
		(date "2026-07-15")
		(rev "C1")
		(company "Gonoboben/plataVM")
		(comment 1 "Symbol skeleton: MAIN_SW1, sensing and safe-off placeholders")
		(comment 2 "No MOSFET, eFuse, ideal-diode, current sensor or footprint selected")
	)
	(lib_symbols)
	(text "13_MAIN_PATH_1 - SYMBOL SKELETON ZONES\nBAT1_TO_MAIN_PATH feeds the future MAIN_SW1 electronic path and then BFE1_SW_OUT.\nMAIN_SW1 is controlled from PCB-B and must fail toward OFF during EXT_KILL/HARD_OFF.\nThis sheet only reserves zones for later real symbols."
		(exclude_from_sim no)
		(at 12 16 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "bfe-lb-00000013-0000-4000-8000-000000000101")
	)
	(text "PLACEHOLDER ZONE: SENSE13_MAIN1_TBD\nFuture current/voltage sensing for MAIN1.\nMay become shunt, Hall, eFuse telemetry or other approved method.\nNo sensor technology or ADC frontend is selected here."
		(exclude_from_sim no)
		(at 12 70 0)
		(effects (font (size 1.22 1.22)) (justify left))
		(uuid "bfe-lb-00000013-0000-4000-8000-000000000102")
	)
	(text "PLACEHOLDER ZONE: MAIN_SW1_TBD\nFuture electronic main switch path for BFE_1.\nTopology, reverse-current policy, SOA, thermal limits and fault timing remain TBD.\nMust not become a central K_MAIN."
		(exclude_from_sim no)
		(at 12 116 0)
		(effects (font (size 1.22 1.22)) (justify left))
		(uuid "bfe-lb-00000013-0000-4000-8000-000000000103")
	)
	(text "PLACEHOLDER ZONE: SAFE_OFF13_TBD\nFuture hardware/software interlock that forces MAIN_SW1 off during EXT_KILL and critical faults.\nSafe-off path must be compatible with independent K_BAT1 hold-loop opening."
		(exclude_from_sim no)
		(at 12 164 0)
		(effects (font (size 1.22 1.22)) (justify left))
		(uuid "bfe-lb-00000013-0000-4000-8000-000000000104")
	)

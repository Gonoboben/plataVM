		(title "13_MAIN_PATH_1 - BFE_1 main electronic path")
		(date "2026-07-15")
		(rev "A1")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A: MAIN_SW1 functional boundary")
		(comment 2 "No MAIN_SW1 topology or component selected")
	)
	(lib_symbols)
	(text "13_MAIN_PATH_1 - FUNCTIONAL PATH\nBAT1_TO_MAIN_PATH -> input protection / current measurement TBD -> MAIN_SW1 -> PACK_BUS contribution.\nMAIN_SW1 is an electronic power path controlled by PCB-B and disabled by EXT_KILL/HARD_OFF.\nThis sheet does not select MOSFETs, eFuse, ideal-diode controller, current sensor or thermal solution."
		(exclude_from_sim no)
		(at 12 18 0)
		(effects (font (size 1.45 1.45)) (justify left))
		(uuid "bfe-dh-00000013-0000-4000-8000-000000000101")
	)
	(text "REQUIRED BEHAVIOR\n- allow controlled connection of BAT1 branch to PACK_BUS;\n- support load-shedding before mechanical K_BAT1 opens;\n- report voltage/current/fault state to PCB-B;\n- fail toward OFF under EXT_KILL and critical faults;\n- preserve independent branch behavior against BFE_2."
		(exclude_from_sim no)
		(at 12 78 0)
		(effects (font (size 1.35 1.35)) (justify left))
		(uuid "bfe-dh-00000013-0000-4000-8000-000000000102")
	)
	(text "OPEN ITEMS\nMAIN_SW1 topology, reverse-current policy, SOA, current-sense method, thermal limits and fault timing remain TBD.\nDo not add K_MAIN. Do not route all PACK_BUS current through PCB-B_CTRL_RESERVE."
		(exclude_from_sim no)
		(at 12 140 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "bfe-dh-00000013-0000-4000-8000-000000000103")
	)
	(hierarchical_label "BAT1_TO_MAIN_PATH" (shape passive) (exclude_from_sim no) (at 120 52 0) (effects (font (size 1.15 1.15)) (justify left)) (uuid "bfe-dh-00000013-0000-4000-8000-000000000201"))
	(hierarchical_label "MAIN_SW1_TO_PACK_BUS" (shape passive) (exclude_from_sim no) (at 120 64 0) (effects (font (size 1.15 1.15)) (justify left)) (uuid "bfe-dh-00000013-0000-4000-8000-000000000202"))
	(hierarchical_label "CTRL_MAIN_SW1_EN" (shape input) (exclude_from_sim no) (at 120 96 0) (effects (font (size 1.15 1.15)) (justify left)) (uuid "bfe-dh-00000013-0000-4000-8000-000000000203"))

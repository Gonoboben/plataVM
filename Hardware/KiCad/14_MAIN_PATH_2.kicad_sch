	(title_block
		(title "14_MAIN_PATH_2 - BFE_2 main electronic path")
		(date "2026-07-15")
		(rev "B1")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level B: MAIN_SW2 control, diagnostics and safe-state nets")
		(comment 2 "Symmetric to 13_MAIN_PATH_1; no MAIN_SW2 topology selected")
	)
	(lib_symbols)
	(text "14_MAIN_PATH_2 - LEVEL B FUNCTIONAL NETS\nBAT2_TO_MAIN_PATH enters the BFE_2 electronic path.\nMAIN_SW2_INPUT and MAIN_SW2_OUTPUT are functional nodes around MAIN_SW2_TBD.\nMAIN_SW2_OUTPUT becomes BFE2_SW_OUT and later joins PACK_BUS_NODE on sheet 16."
		(exclude_from_sim no)
		(at 12 18 0)
		(effects (font (size 1.35 1.35)) (justify left))
		(uuid "bfe-lb-00000014-0000-4000-8000-000000000101")
	)
	(text "CONTROL AND SAFE STATE\nCTRL_MAIN_SW2_EN enables the branch only when allowed by firmware and hardware safety.\nMAIN_SW2_SAFE_OFF and EXT_KILL_HW_CHAIN must force the branch OFF independent of normal load commands.\nReverse current policy, precharge/inrush handling and SOA remain TBD."
		(exclude_from_sim no)
		(at 12 78 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "bfe-lb-00000014-0000-4000-8000-000000000102")
	)
	(text "DIAGNOSTICS\nDIAG_MAIN2_I, DIAG_MAIN2_VIN, DIAG_MAIN2_VOUT and DIAG_MAIN2_FAULT are grouped outputs to PCB-B.\nMeasurement topology and ADC frontend remain TBD.\nDo not add K_MAIN or route all PACK_BUS current through PCB-B_CTRL_RESERVE."
		(exclude_from_sim no)
		(at 12 140 0)
		(effects (font (size 1.25 1.25)) (justify left))
		(uuid "bfe-lb-00000014-0000-4000-8000-000000000103")
	)

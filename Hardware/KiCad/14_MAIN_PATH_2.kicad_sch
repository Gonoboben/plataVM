	(title_block
		(title "14_MAIN_PATH_2 - BFE_2 main electronic path")
		(date "2026-07-15")
		(rev "C2")
		(company "Gonoboben/plataVM")
		(comment 1 "Interface consistency: canonical BAT2 main-switch control and hardware-off boundaries")
		(comment 2 "Symmetric to 13_MAIN_PATH_1; no topology, footprint or component selected")
	)
	(lib_symbols)
	(text "14_MAIN_PATH_2 - SYMBOL SKELETON ZONES\nBAT2_TO_MAIN_PATH feeds the future MAIN_SW2 electronic path and then BFE2_SW_OUT.\nBAT2_MAIN_SW_EN is the canonical normal-control enable from PCB-B.\nBAT2_MAIN_SW_OFF_HW and EXT_KILL_HW_CHAIN force the branch toward OFF independently of firmware."
		(exclude_from_sim no)
		(at 12 16 0)
		(effects (font (size 1.3 1.3)) (justify left))
		(uuid "bfe-lb-00000014-0000-4000-8000-000000000101")
	)
	(text "PLACEHOLDER ZONE: SENSE14_MAIN2_TBD\nFuture current/voltage sensing for MAIN2.\nMay become shunt, Hall, eFuse telemetry or other approved method.\nNo sensor technology or ADC frontend is selected here."
		(exclude_from_sim no)
		(at 12 70 0)
		(effects (font (size 1.22 1.22)) (justify left))
		(uuid "bfe-lb-00000014-0000-4000-8000-000000000102")
	)
	(text "PLACEHOLDER ZONE: MAIN_SW2_TBD\nFuture electronic main switch path for BFE_2.\nTopology, reverse-current policy, SOA, thermal limits and fault timing remain TBD.\nMust remain symmetric with MAIN_SW1 unless a documented reason exists."
		(exclude_from_sim no)
		(at 12 116 0)
		(effects (font (size 1.22 1.22)) (justify left))
		(uuid "bfe-lb-00000014-0000-4000-8000-000000000103")
	)
	(text "PLACEHOLDER ZONE: SAFE_OFF14_TBD\nFuture hardware/software interlock that forces MAIN_SW2 off during EXT_KILL and critical faults.\nBAT2_MAIN_SW_OFF_HW is the branch-specific final action from the independent EXT_KILL fanout.\nSafe-off behavior must remain compatible with independent K_BAT2 hold-loop opening."
		(exclude_from_sim no)
		(at 12 164 0)
		(effects (font (size 1.18 1.18)) (justify left))
		(uuid "bfe-lb-00000014-0000-4000-8000-000000000104")
	)

	(title_block
		(title "32_POWER_12V_CHANNEL_TEMPLATE - single-channel functional contract")
		(date "2026-07-15")
		(rev "B0")
		(company "Gonoboben/plataVM")
		(comment 1 "Architecture Level A/B: reusable 3 A channel control/protection/diagnostic boundary")
		(comment 2 "No high-side switch, eFuse, current sensor, suppression, connector or footprint selected")
	)
	(lib_symbols)
	(text "32_POWER_12V_CHANNEL_TEMPLATE - PURPOSE\nDefines the functional contract common to each of the fourteen PCB-C output channels.\nNominal continuous requirement is 3 A per channel, subject to branch-total, thermal and load-profile calculations.\nThis template is architectural and does not instantiate a selected component."
		(exclude_from_sim no)
		(at 12 14 0)
		(effects (font (size 1.22 1.22)) (justify left))
		(uuid "power-12v-00000032-0000-4000-8000-000000000101")
	)
	(text "CONTROL / SAFE STATE\nP12_CH_EN is used for normally controlled channels; an Always-On channel may bind it to the approved always-enabled policy.\nP12_CH_SAFE_OFF and P12_CH_HARD_OFF have priority over normal enable.\nReset, unpowered-control and disconnected-control states must resolve to the channel-specific safe state."
		(exclude_from_sim no)
		(at 12 74 0)
		(effects (font (size 1.12 1.12)) (justify left))
		(uuid "power-12v-00000032-0000-4000-8000-000000000102")
	)
	(text "PROTECTION / LOAD BEHAVIOR\nFuture topology must limit or interrupt overload/short-circuit energy and contain single-channel faults.\nInductive turn-off, capacitive inrush, reverse current, repetitive cycling and output discharge requirements are load-dependent and remain TBD.\nA fault should not disable unrelated channels unless upstream branch protection requires it."
		(exclude_from_sim no)
		(at 12 138 0)
		(effects (font (size 1.10 1.10)) (justify left))
		(uuid "power-12v-00000032-0000-4000-8000-000000000103")
	)
	(text "DIAGNOSTIC CONTRACT\nEach channel provides P12_CH_FAULT_N and P12_CH_ISENSE.\nOptional local status/temperature observability may be added after topology selection.\nFault polarity conditioning, current range, accuracy, filtering and diagnostic transport remain TBD."
		(exclude_from_sim no)
		(at 12 210 0)
		(effects (font (size 1.12 1.12)) (justify left))
		(uuid "power-12v-00000032-0000-4000-8000-000000000104")
	)
